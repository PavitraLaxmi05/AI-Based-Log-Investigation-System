        "\n",
        "LLM_MODEL = \"llama-3.3-70b-versatile\"\n",
        "MAX_TOKENS = 300\n",
        "TEMPERATURE = 0.1\n",
        "LLM_CACHE = {}\n",
        "BASE_PATH = \"/content/drive/MyDrive/Colab Notebooks\"\n",
        "\n",
        "def call_llm_safe(client, prompt, retries=3, backoff=5):\n",
        "    key = hashlib.md5(prompt.encode()).hexdigest()\n",
        "    if key in LLM_CACHE:\n",
        "        return LLM_CACHE[key]\n",
        "    for attempt in range(retries):\n",
        "        try:\n",
        "            response = client.chat.completions.create(\n",
        "                model=LLM_MODEL,\n",
        "                messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "                temperature=TEMPERATURE,\n",
        "                max_tokens=MAX_TOKENS\n",
        "            )\n",
        "            output = response.choices[0].message.content.strip()\n",
        "            LLM_CACHE[key] = output\n",
        "            return output\n",
        "        except Exception as e:\n",
        "            err = str(e)\n",
        "            if \"rate_limit\" in err.lower():\n",
        "                time.sleep(backoff * (attempt + 1))\n",
        "            else:\n",
        "                return f\"[LLM ERROR: {err}]\"\n",
        "    return \"[LLM SKIPPED: RATE LIMIT]\"\n",
        "\n",
        "def get_llm_windows_narrative(row_dict):\n",
        "    prompt = f\"\"\"You are a senior Windows Forensic Lead. Analyze this security event.\n",
        "\n",
        "EVENT CONTEXT:\n",
