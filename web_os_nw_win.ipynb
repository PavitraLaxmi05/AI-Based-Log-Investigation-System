      "source": [
        "# ==============================\n",
        "# APPLICATION LOG — DECODER + LLM\n",
        "# ==============================\n",
        "\n",
        "APP_FEATURE_DESCRIPTIONS = {\n",
        "    \"path_length\": \"length of the HTTP request path in characters (long = possible injection or traversal)\",\n",
        "    \"request_depth\": \"number of '/' separators in the path (deep = directory traversal attempt)\",\n",
        "    \"path_entropy\": \"Shannon entropy of path characters (high = encoded/obfuscated payload)\",\n",
        "    \"depth_per_length\": \"request depth normalised by path length\",\n",
        "    \"entropy_per_length\": \"entropy normalised by path length (high = complex obfuscated path)\",\n",
        "    \"is_night\": \"1 if request occurred between 22:00–06:00 (off-hours activity)\",\n",
        "    \"hour\": \"hour of request (0-23)\",\n",
        "    \"protocol\": \"encoded protocol type (HTTP/HTTPS/other)\",\n",
        "    \"action\": \"encoded HTTP method (GET/POST/PUT/DELETE/etc.)\",\n",
        "    \"log_type\": \"encoded application log category\",\n",
        "    \"status_code\": \"HTTP response status code (4xx = client error, 5xx = server error)\",\n",
        "    \"response_size\": \"size of HTTP response body in bytes\",\n",
        "    \"bytes_sent\": \"bytes sent by client in request\",\n",
        "}\n",
        "\n",
        "HTTP_STATUS_MAP = {\n",
        "    200: \"OK\", 201: \"Created\", 204: \"No Content\",\n",
        "    301: \"Redirect\", 302: \"Redirect\",\n",
        "    400: \"Bad Request\", 401: \"Unauthorized — auth failure\",\n",
        "    403: \"Forbidden — access denied\", 404: \"Not Found\",\n",
        "    405: \"Method Not Allowed\", 429: \"Rate Limited\",\n",
        "    500: \"Internal Server Error\", 502: \"Bad Gateway\", 503: \"Service Unavailable\"\n",
        "}\n",
        "\n",
        "\n",
        "def decode_app_log_context(row_dict):\n",
        "    \"\"\"Decode application log fields for LLM consumption.\"\"\"\n",
        "    path = str(row_dict.get(\"request_path\", row_dict.get(\"path\", \"N/A\")))\n",
        "    src_ip = str(row_dict.get(\"src_ip\", row_dict.get(\"client_ip\",\n",
        "                      row_dict.get(\"IPV4_SRC_ADDR\", \"N/A\"))))\n",
        "    method = str(row_dict.get(\"method\", row_dict.get(\"request_method\", \"N/A\")))\n",
        "    status_raw = row_dict.get(\"status_code\", row_dict.get(\"response_code\", \"N/A\"))\n",
        "    user_agent = str(row_dict.get(\"user_agent\", row_dict.get(\"useragent\", \"N/A\")))\n",
        "    host = str(row_dict.get(\"host\", row_dict.get(\"server_name\", \"N/A\")))\n",
        "\n",
        "    try:\n",
        "        status_int = int(float(status_raw))\n",
        "        status_str = f\"{status_int} — {HTTP_STATUS_MAP.get(status_int, 'unknown')}\"\n",
        "    except (ValueError, TypeError):\n",
        "        status_str = str(status_raw)\n",
        "\n",
        "    path_length = float(row_dict.get(\"path_length\", len(path) if path != \"N/A\" else 0))\n",
        "    depth = float(row_dict.get(\"request_depth\", path.count('/') if path != \"N/A\" else 0))\n",
        "    entropy = float(row_dict.get(\"path_entropy\", 0))\n",
        "    is_night = bool(row_dict.get(\"is_night\", 0))\n",
        "    hour = int(float(row_dict.get(\"hour\", 0)))\n",
        "\n",
        "    # Heuristic attack signal flags\n",
        "    path_lower = path.lower()\n",
        "    sqli_signals = any(x in path_lower for x in [\"'\", \"union\", \"select\", \"drop\", \"--\", \"1=1\", \"or 1\"])\n",
        "    xss_signals = any(x in path_lower for x in [\"<script\", \"javascript:\", \"onerror\", \"alert(\"])\n",
        "    traversal = \"../\" in path or \"..%2f\" in path_lower or \"%2e%2e\" in path_lower\n",
        "    cmd_injection = any(x in path_lower for x in [\";\", \"|\", \"`\", \"$(\", \"&&\", \"||\", \"cmd=\", \"exec=\"])\n",
        "    scanner_ua = any(x in user_agent.lower() for x in\n",
        "                        [\"sqlmap\", \"nikto\", \"nmap\", \"masscan\", \"gobuster\",\n",
        "                         \"dirbuster\", \"burp\", \"zap\", \"nuclei\", \"hydra\"])\n",
        "\n",
        "    attack_hints = []\n",
        "    if sqli_signals:   attack_hints.append(\"SQL injection pattern in path\")\n",
        "    if xss_signals:    attack_hints.append(\"XSS pattern in path\")\n",
        "    if traversal:      attack_hints.append(\"directory traversal sequence detected\")\n",
        "    if cmd_injection:  attack_hints.append(\"command injection characters in path\")\n",
        "    if scanner_ua:     attack_hints.append(f\"known attack tool user-agent: {user_agent}\")\n",
        "    if entropy > 3.5:  attack_hints.append(f\"high path entropy ({entropy:.2f}) — possible obfuscated payload\")\n",
        "    if depth > 6:      attack_hints.append(f\"deep path ({depth:.0f} levels) — possible traversal\")\n",
        "    if is_night:       attack_hints.append(f\"request at {hour:02d}:xx — off-hours activity\")\n",
        "\n",
        "    return {\n",
        "        \"src_ip\": src_ip,\n",
        "        \"method\": method,\n",
        "        \"path\": path,\n",
        "        \"host\": host,\n",
        "        \"status_str\": status_str,\n",
        "        \"user_agent\": user_agent,\n",
        "        \"path_length\": path_length,\n",
        "        \"depth\": depth,\n",
        "        \"entropy\": entropy,\n",
        "        \"is_night\": is_night,\n",
        "        \"hour\": hour,\n",
        "        \"attack_hints\": attack_hints,\n",
        "    }\n",
        "\n",
        "\n",
        "def get_llm_app_narrative(row_dict, contributions, prob):\n",
        "    \"\"\"LLM forensic narrative for a single application log.\"\"\"\n",
        "    ctx = decode_app_log_context(row_dict)\n",
        "\n",
        "    shap_lines = []\n",
        "    for feat, impact in contributions[:5]:\n",
        "        direction = \"RAISED\" if impact > 0 else \"LOWERED\"\n",
        "        raw_val = row_dict.get(feat, \"N/A\")\n",
        "        desc = APP_FEATURE_DESCRIPTIONS.get(feat, feat)\n",
        "        shap_lines.append(\n",
        "            f\"  [{direction} threat by {abs(impact):.4f}]  {feat} = {raw_val}  |  {desc}\"\n",
        "        )\n",
        "    shap_block = \"\\n\".join(shap_lines)\n",
        "\n",
        "    hints_block = \"\\n  - \".join(ctx[\"attack_hints\"]) if ctx[\"attack_hints\"] else \"No obvious attack patterns detected\"\n",
        "\n",
        "    if prob < 0.40:\n",
        "        confidence_instruction = f\"ML confidence is only {prob:.1%} — treat as low-confidence flag, focus on observation.\"\n",
        "    elif prob < 0.65:\n",
        "        confidence_instruction = f\"ML confidence is {prob:.1%} — moderate suspicion, investigate before acting.\"\n",
        "    else:\n",
        "        confidence_instruction = f\"ML confidence is {prob:.1%} — high confidence, recommend immediate action.\"\n",
        "\n",
        "    prompt = f\"\"\"You are a senior web application security analyst writing a forensic report entry.\n",
        "{confidence_instruction}\n",
        "\n",
        "REQUEST DETAILS:\n",
        "  Source IP     : {ctx['src_ip']}\n",
        "  Method        : {ctx['method']}\n",
        "  Path          : {ctx['path'][:200]}\n",
        "  Status code   : {ctx['status_code']}\n",
        "  User-Agent    : {ctx['user_agent'][:100]}\n",
        "  Path length   : {ctx['path_length']:.0f} chars\n",
        "  Path depth    : {ctx['depth']:.0f} levels\n",
        "  Path entropy  : {ctx['entropy']:.3f}\n",
        "  Time of day   : {ctx['hour']:02d}:xx {'(OFF-HOURS)' if ctx['is_night'] else '(business hours)'}\n",
        "  ML Confidence : {prob:.1%} MALICIOUS\n",
        "\n",
        "AUTOMATED PATTERN DETECTION:\n",
        "  - {hints_block}\n",
        "\n",
        "TOP SHAP CONTRIBUTORS:\n",
        "{shap_block}\n",
        "\n",
        "INTERPRETATION GUIDE:\n",
        "  - High entropy (>3.5) in path = encoded or obfuscated characters — possible payload evasion.\n",
        "  - Deep path (>6 levels) with ../ or %2e%2e = directory traversal attempt.\n",
        "  - SQLi: look for quotes, UNION, SELECT, OR 1=1 in path or parameters.\n",
        "  - XSS: look for <script>, javascript:, onerror= in path.\n",
        "  - Scanner UA (sqlmap, nikto, nmap, burp) = automated attack tool, not a human.\n",
        "  - 403/401 responses to suspicious paths = WAF or auth blocking the attack.\n",
        "  - 200 response to suspicious path = attack may have SUCCEEDED — highest priority.\n",
        "  - Off-hours requests from single IP with varied paths = scanning or brute force.\n",
        "\n",
        "Respond in EXACTLY this format:\n",
        "\n",
        "VERDICT:\n",
        "[2 sentences. What does this web request most likely represent? Cite the path, status code, and entropy specifically.]\n",
        "\n",
        "ATTACK VECTOR:\n",
        "[1 sentence. Name the web attack class (SQLi, XSS, path traversal, scanner, brute force, RFI/LFI, SSRF) and cite 2-3 specific values.]\n",
        "\n",
        "REMEDIATION:\n",
        "1. [WAF or firewall rule specific to the src IP or path pattern observed]\n",
        "2. [Detection rule using entropy threshold, path depth, or status code pattern]\n",
        "3. [Investigation step: check server logs for successful exploitation or lateral movement]\"\"\"\n",
        "\n",
        "    try:\n",
        "        response = groq_client.chat.completions.create(\n",
        "            model=\"llama-3.3-70b-versatile\",\n",
        "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "            temperature=0.1,\n",
        "            max_tokens=500\n",
        "        )\n",
        "        return response.choices[0].message.content.strip()\n",
        "    except Exception as e:\n",
        "        return f\"[LLM unavailable: {e}]\"\n",
        "\n",
        "\n",
