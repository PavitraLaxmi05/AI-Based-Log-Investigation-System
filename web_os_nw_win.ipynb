        "\n",
        "def generate_application_explanation(df, gate_probs, final_pred, combined_score):\n",
        "    \"\"\"\n",
        "    Generate SHAP explanation and LLM forensic narrative for application logs.\n",
        "    FIXED: Proper feature alignment and SHAP calculation.\n",
        "    \"\"\"\n",
        "    try:\n",
        "        malicious_idx = np.where(final_pred == 1)[0]\n",
        "        if len(malicious_idx) == 0:\n",
        "            return \"No malicious application logs detected — no explanation needed.\"\n",
        "\n",
        "        top_n = min(5, len(malicious_idx))\n",
        "        # Sort by combined score (highest confidence first)\n",
        "        top_local = malicious_idx[np.argsort(combined_score[malicious_idx])[::-1][:top_n]]\n",
        "\n",
        "        text = \"=\" * 60 + \"\\n\"\n",
        "        text += \"  AI FORENSIC EXPLANATION — TOP SUSPICIOUS APPLICATION LOGS\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\\n\"\n",
        "\n",
        "        all_app_contexts = []\n",
        "\n",
        "        for rank, idx in enumerate(top_local):\n",
        "            prob_val = combined_score[idx]\n",
        "            row_data = df.iloc[idx]\n",
        "            row_dict = row_data.to_dict()\n",
        "\n",
        "            # ============================================================\n",
        "            # FIX: Properly preprocess the row for SHAP\n",
        "            # ============================================================\n",
        "            # Create a single-row DataFrame\n",
        "            single_row = pd.DataFrame([row_data])\n",
        "\n",
        "            # Preprocess using the same function as the main pipeline\n",
        "            X_processed = preprocess_application_logs(single_row)\n",
        "\n",
        "            # Ensure all expected features are present\n",
        "            expected_features = app_gatekeeper_model.feature_names_in_\n",
        "            for col in expected_features:\n",
        "                if col not in X_processed.columns:\n",
        "                    X_processed[col] = 0\n",
        "\n",
        "            # Reorder columns to match model's expected order\n",
        "            X_processed = X_processed[expected_features]\n",
        "            X_processed = X_processed.fillna(0).astype(np.float32)\n",
        "\n",
        "            # Get SHAP values using TreeExplainer\n",
        "            try:\n",
        "                # Create explainer once and reuse (better performance)\n",
        "                if not hasattr(generate_application_explanation, \"explainer\"):\n",
        "                    generate_application_explanation.explainer = shap.TreeExplainer(app_gatekeeper_model)\n",
        "\n",
        "                shap_values = generate_application_explanation.explainer.shap_values(X_processed)\n",
        "\n",
        "                # Handle binary classification output\n",
        "                if isinstance(shap_values, list):\n",
        "                    # For binary classification, shap_values[1] is for class 1 (malicious)\n",
        "                    sv = shap_values[1][0] if len(shap_values) > 1 else shap_values[0][0]\n",
        "                else:\n",
        "                    sv = shap_values[0]\n",
        "\n",
        "                # Create contributions list with non-zero values\n",
        "                contributions = []\n",
        "                for i, feat in enumerate(expected_features):\n",
        "                    if abs(sv[i]) > 0.0001:  # Only include features with meaningful impact\n",
        "                        contributions.append((feat, sv[i]))\n",
        "\n",
        "                # Sort by absolute impact and take top 8\n",
        "                contributions = sorted(contributions, key=lambda x: abs(x[1]), reverse=True)[:8]\n",
        "\n",
        "                # If still no contributions, show top features even with zero values\n",
        "                if not contributions:\n",
        "                    contributions = [(feat, sv[i]) for i, feat in enumerate(expected_features[:8])]\n",
        "\n",
        "            except Exception as e:\n",
        "                print(f\"SHAP error for app log {rank}: {e}\")\n",
        "                contributions = []\n",
        "                # Fallback: use gatekeeper feature importance\n",
        "                if hasattr(app_gatekeeper_model, 'feature_importances_'):\n",
        "                    importances = app_gatekeeper_model.feature_importances_\n",
        "                    contributions = [(expected_features[i], importances[i]) for i in range(min(8, len(expected_features)))]\n",
        "\n",
        "            text += f\"LOG #{rank+1}  —  Threat Confidence: {prob_val:.1%}\\n\"\n",
        "            text += \"-\" * 50 + \"\\n\"\n",
        "\n",
        "            # Display key request details\n",
        "            text += f\"  Request Path    : {row_data.get('request_path', 'N/A')[:100]}\\n\"\n",
        "            text += f\"  Method          : {row_data.get('method', row_data.get('request_method', 'N/A'))}\\n\"\n",
        "            text += f\"  Source IP       : {row_data.get('src_ip', row_data.get('source_ip', 'N/A'))}\\n\"\n",
        "            text += f\"  Status Code     : {row_data.get('status_code', row_data.get('response_code', 'N/A'))}\\n\"\n",
        "            text += f\"  User-Agent      : {row_data.get('user_agent', 'N/A')[:80]}\\n\\n\"\n",
        "\n",
        "            text += \"  Top Contributing Features (SHAP):\\n\"\n",
        "            if contributions:\n",
        "                for feat, impact in contributions:\n",
        "                    direction = \"↑ increased\" if impact > 0 else \"↓ reduced\"\n",
        "                    # Get the actual value from the preprocessed data\n",
        "                    if feat in X_processed.columns:\n",
        "                        val = X_processed[feat].values[0]\n",
        "                    else:\n",
        "                        val = row_data.get(feat, 0)\n",
        "\n",
        "                    bar = \"█\" * int(min(abs(impact) * 100, 20))\n",
        "                    desc = APP_FEATURE_DESCRIPTIONS.get(feat, \"\")\n",
        "\n",
        "                    # Format the feature name for display\n",
        "                    display_feat = feat[:28]\n",
        "                    text += f\"    • {display_feat:<28} = {float(val):>10.4f}  → {direction} threat  (SHAP: {impact:+.4f}) {bar}\\n\"\n",
        "                    if desc:\n",
        "                        text += f\"      ↳ {desc}\\n\"\n",
        "            else:\n",
        "                text += \"    No SHAP contributions available — using rule-based detection\\n\"\n",
        "                # Show rule-based indicators\n",
        "                if 'request_path' in row_dict:\n",
        "                    path = str(row_dict.get('request_path', ''))\n",
        "                    if 'adminer.php' in path:\n",
        "                        text += \"    • 🔴 CRITICAL: Adminer.php access detected — database management interface\\n\"\n",
        "                    if 'root' in path or 'admin' in path:\n",
        "                        text += \"    • 🔴 CRITICAL: Root/admin privilege attempt\\n\"\n",
        "                    if 'Nmap' in str(row_dict.get('user_agent', '')):\n",
        "                        text += \"    • 🟠 HIGH: Nmap scanner detected — automated attack tool\\n\"\n",
        "\n",
        "            text += \"\\n  AI FORENSIC NARRATIVE (Groq / LLaMA-3.3-70B):\\n\"\n",
        "            text += \"  \" + \"-\" * 48 + \"\\n\"\n",
        "\n",
        "            # Call LLM for this log\n",
        "            llm_text = get_llm_app_narrative(row_dict, contributions[:5] if contributions else [], prob_val)\n",
        "            for line in llm_text.split(\"\\n\"):\n",
        "                text += f\"  {line}\\n\"\n",
        "            text += \"\\n\"\n",
        "\n",
        "            # Collect context for cross-log pattern analysis\n",
        "            all_app_contexts.append(decode_app_log_context(row_dict))\n",
        "\n",
        "        # Cross-log pattern summary\n",
        "        if all_app_contexts:\n",
        "            text += \"=\" * 60 + \"\\n\"\n",
        "            text += \"  CROSS-LOG PATTERN ANALYSIS (Threat Hunter View)\\n\"\n",
        "            text += \"=\" * 60 + \"\\n\"\n",
        "            pattern_text = get_llm_app_pattern_summary(all_app_contexts)\n",
        "            for line in pattern_text.split(\"\\n\"):\n",
        "                text += f\"  {line}\\n\"\n",
        "            text += \"\\n\"\n",
        "\n",
        "        total_malicious = len(malicious_idx)\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        text += f\"  BATCH SUMMARY: {total_malicious} malicious application logs detected.\\n\"\n",
        "        text += f\"  Full LLM analysis shown for top {top_n} highest-confidence alerts.\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "\n",
        "        return text\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        return f\"Application explanation error:\\n{traceback.format_exc()}\"\n",
        "\n",
        "\n",
        "# ==============================\n",
        "# FIXED process_application_logs with SHAP + LLM integration\n",
        "# ==============================\n",
        "\n",
        "def process_application_logs(file_obj):\n",
        "    import math\n",
        "    import pandas as pd\n",
        "    import numpy as np\n",
        "    from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix\n",
        "    from sklearn.metrics import precision_recall_curve\n",
        "\n",
        "    try:\n",
        "        df = pd.read_csv(file_obj.name)\n",
        "\n",
        "        print(f\"\\n{'='*60}\")\n",
        "        print(f\"DEBUG: Raw data loaded - Shape: {df.shape}\")\n",
        "\n",
        "        # =========================\n",
        "        # SAVE LABEL IF EXISTS\n",
        "        # =========================\n",
        "        y_true_raw = None\n",
        "        if \"threat_label\" in df.columns:\n",
        "            y_true_raw = df[\"threat_label\"].copy()\n",
        "            actual_malicious = (y_true_raw == 'malicious').sum()\n",
        "            actual_benign = (y_true_raw == 'benign').sum()\n",
        "            print(f\"DEBUG: Actual Malicious: {actual_malicious}, Actual Benign: {actual_benign}\")\n",
        "\n",
        "        # =========================\n",
        "        # PREPROCESS FOR GATEKEEPER\n",
        "        # =========================\n",
        "        X_processed = preprocess_application_logs(df)\n",
        "\n",
        "        # =========================\n",
        "        # GATEKEEPER PREDICTIONS\n",
        "        # =========================\n",
        "        gate_probs = app_gatekeeper_model.predict_proba(X_processed)[:, 1]\n",
        "\n",
        "        # =========================\n",
        "        # CALCULATE THREAT SCORE FROM PATH FEATURES\n",
        "        # =========================\n",
        "        if 'request_path' in df.columns:\n",
        "            df['request_path'] = df['request_path'].astype(str)\n",
        "\n",
        "            # Strong indicators (high confidence)\n",
        "            has_sql = df['request_path'].str.lower().apply(\n",
        "                lambda x: 1 if any(kw in x for kw in ['select', 'union', 'insert', 'drop', 'delete', 'exec', 'from', 'where']) else 0\n",
        "            )\n",
        "            has_traversal = df['request_path'].apply(\n",
        "                lambda x: 1 if '../' in x or '..\\\\' in x else 0\n",
        "            )\n",
        "            has_command = df['request_path'].apply(\n",
        "                lambda x: 1 if any(cmd in x for cmd in [';', '|', '&', '$', '`', 'wget', 'curl', 'nc', 'bash', 'sh']) else 0\n",
        "            )\n",
        "            has_sensitive = df['request_path'].str.lower().apply(\n",
        "                lambda x: 1 if any(f in x for f in ['passwd', 'shadow', 'env', 'config', 'sql', 'bak', 'backup']) else 0\n",
        "            )\n",
        "            has_special = df['request_path'].apply(\n",
        "                lambda x: 1 if any(c in x for c in ['?', '=', '<', '>', '%', \"'\", '\"', ';', '-', '{', '}']) else 0\n",
        "            )\n",
        "            is_deep = (df['request_path'].str.count('/') > 4).astype(int)\n",
        "            is_long = (df['request_path'].str.len() > 80).astype(int)\n",
        "\n",
        "            # Weighted threat score (0-100)\n",
        "            threat_score = (\n",
        "                has_sql * 40 +\n",
        "                has_traversal * 40 +\n",
        "                has_command * 35 +\n",
        "                has_sensitive * 30 +\n",
        "                has_special * 20 +\n",
        "                is_deep * 15 +\n",
        "                is_long * 10\n",
        "            )\n",
        "            threat_score_norm = np.clip(threat_score / 40, 0, 1)\n",
        "        else:\n",
        "            threat_score_norm = np.zeros(len(df))\n",
        "\n",
        "        # =========================\n",
        "        # COMBINED SCORE (BALANCED)\n",
        "        # =========================\n",
        "        # 50% gatekeeper, 50% threat score for balance\n",
        "        combined_score = (gate_probs * 0.5) + (threat_score_norm * 0.5)\n",
        "\n",
        "        # =========================\n",
        "        # DYNAMIC THRESHOLD\n",
        "        # =========================\n",
        "        threshold = np.percentile(combined_score, 40)\n",
        "        threshold = max(0.35, min(threshold, 0.55))\n",
        "\n",
        "        print(f\"DEBUG: Combined score range: {combined_score.min():.3f} - {combined_score.max():.3f}\")\n",
        "        print(f\"DEBUG: Using threshold: {threshold:.3f}\")\n",
        "\n",
        "        # Initial prediction\n",
        "        final_pred = (combined_score >= threshold).astype(int)\n",
        "\n",
        "        # =========================\n",
        "        # MALICIOUS OVERRIDE\n",
        "        # =========================\n",
        "        if 'request_path' in df.columns:\n",
        "            strong_malicious = (\n",
        "                (has_sql == 1) |\n",
        "                (has_traversal == 1) |\n",
        "                (has_command == 1) |\n",
        "                ((has_sensitive == 1) & (has_special == 1)) |\n",
        "                ((threat_score_norm > 0.6) & (gate_probs > 0.3))\n",
        "            )\n",
        "            final_pred[strong_malicious] = 1\n",
        "            final_pred[threat_score_norm > 0.65] = 1\n",
        "\n",
        "        # =========================\n",
        "        # BENIGN OVERRIDE\n",
        "        # =========================\n",
        "        if 'request_path' in df.columns:\n",
        "            safe_benign = (\n",
        "                (gate_probs < 0.2) &\n",
        "                (threat_score_norm < 0.1) &\n",
        "                (df['request_path'].str.len() < 50) &\n",
        "                (df['request_path'].str.count('/') < 3)\n",
        "            )\n",
        "            final_pred[safe_benign] = 0\n",
        "\n",
        "        # =========================\n",
        "        # FINAL VERDICT\n",
        "        # =========================\n",
        "        malicious_count = int(final_pred.sum())\n",
        "        benign_count = len(df) - malicious_count\n",
        "        severity = (malicious_count / len(df)) * 100 if len(df) > 0 else 0\n",
        "\n",
        "        result_df = df.copy()\n",
        "        result_df[\"Verdict\"] = np.where(final_pred == 1, \"MALICIOUS\", \"BENIGN\")\n",
        "        result_df[\"__row_id\"] = [str(i) for i in range(len(result_df))]\n",
        "\n",
        "        # Create gauge\n",
        "        try:\n",
        "            gauge = create_gauge(severity)\n",
        "        except:\n",
        "            gauge = None\n",
        "\n",
        "        # =========================\n",
        "        # GENERATE SHAP + LLM EXPLANATION\n",
        "        # =========================\n",
        "        forensic_explanation = generate_application_explanation(df, gate_probs, final_pred, combined_score)\n",
        "\n",
        "        # =========================\n",
        "        # REPORT\n",
        "        # =========================\n",
        "        report = f\"\"\"\n",
        "{'='*60}\n",
        "FORENSIC STREAM REPORT — APPLICATION LOGS (BALANCED)\n",
        "{'='*60}\n",
        "\n",
        "TOTAL LOGS PROCESSED\n",
        "------------------------------------------------------------\n",
        "Total logs processed : {len(df):,}\n",
        "Predicted BENIGN    : {benign_count:,}\n",
        "Predicted MALICIOUS : {malicious_count:,}\n",
        "Threat severity     : {severity:.1f}%\n",
        "\n",
        "MODEL CONFIGURATION\n",
        "------------------------------------------------------------\n",
        "Decision threshold  : {threshold:.3f}\n",
        "Strategy            : 50% Gatekeeper + 50% Threat Score\n",
        "\n",
        "FINAL VERDICT\n",
        "------------------------------------------------------------\n",
        "Total BENIGN         : {benign_count:,}\n",
        "Total MALICIOUS      : {malicious_count:,}\n",
        "\"\"\"\n",
        "\n",
        "        # =========================\n",
        "        # METRICS (if labels exist)\n",
        "        # =========================\n",
        "        if \"threat_label\" in df.columns:\n",
        "            y_true = df[\"threat_label\"].apply(\n",
        "                lambda x: 1 if str(x).lower() == \"malicious\" else 0\n",
        "            ).values\n",
        "\n",
        "            acc = accuracy_score(y_true, final_pred)\n",
        "            prec = precision_score(y_true, final_pred, zero_division=0)\n",
        "            rec = recall_score(y_true, final_pred, zero_division=0)\n",
        "            f1 = f1_score(y_true, final_pred, zero_division=0)\n",
        "            cm = confusion_matrix(y_true, final_pred)\n",
        "\n",
        "            tn, fp, fn, tp = cm.ravel() if cm.size == 4 else (0, 0, 0, 0)\n",
        "\n",
        "            report += f\"\"\"\n",
        "PERFORMANCE METRICS\n",
        "------------------------------------------------------------\n",
        "Accuracy  : {acc:.4f} ({acc*100:.2f}%)\n",
        "Precision : {prec:.4f} ({prec*100:.2f}%)\n",
        "Recall    : {rec:.4f} ({rec*100:.2f}%)\n",
        "F1 Score  : {f1:.4f}\n",
        "\n",
        "CONFUSION MATRIX\n",
        "------------------------------------------------------------\n",
        "True Negatives (Correct Benign)      : {tn:,}\n",
        "False Positives (Benign as Malicious): {fp:,}\n",
        "False Negatives (Malicious as Benign): {fn:,}\n",
        "True Positives (Correct Malicious)   : {tp:,}\n",
        "\n",
        "ERROR RATES\n",
        "------------------------------------------------------------\n",
        "False Positive Rate (FPR) : {(fp/(tn+fp))*100:.2f}% if (tn+fp) > 0 else 0.00%\n",
        "False Negative Rate (FNR) : {(fn/(fn+tp))*100:.2f}% if (fn+tp) > 0 else 0.00%\n",
        "\"\"\"\n",
        "\n",
        "        # =========================\n",
        "        # DISPLAY DATAFRAME\n",
        "        # =========================\n",
        "        df_display = result_df.head(200).copy()\n",
        "        df_display.insert(0, \"Display Time\", pd.Timestamp.now().strftime(\"%H:%M:%S\"))\n",
        "\n",
        "        display_cols = ['Display Time', 'request_path', 'protocol', 'action',\n",
        "                       'bytes_transferred', 'Verdict']\n",
        "        existing_cols = [col for col in display_cols if col in df_display.columns]\n",
        "        df_display = df_display[existing_cols]\n",
        "\n",
        "        return df_display, result_df, report, gauge, forensic_explanation\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        error_msg = f\"ERROR:\\n{traceback.format_exc()}\"\n",
        "        return pd.DataFrame(), pd.DataFrame(), error_msg, None, f\"FAILED: {str(e)}\"\n",
        "\n",
        "def process_windows_logs(file_obj):\n",
        "    try:\n",
        "        # 1. Load Data\n",
        "        df_raw = pd.read_csv(file_obj.name)\n",
        "\n",
        "        # 2. Run Pipeline\n",
        "        df_final = run_windows_pipeline(df_raw)\n",
        "        # 3. Extract Component Statistics\n",
        "        total_logs = len(df_final)\n",
        "        is_anomalous = df_final[\"risk_score\"] >= 1\n",
        "        gate_anomaly_count = int(is_anomalous.sum())\n",
        "        gate_normal_count = total_logs - gate_anomaly_count\n",
        "\n",
        "        main_df = df_final[~is_anomalous]\n",
        "        main_benign = len(main_df)\n",
        "\n",
        "        dlq_df = df_final[is_anomalous]\n",
        "        dlq_malicious = int((dlq_df[\"mlp_flag\"] == 1).sum())\n",
        "        dlq_benign = len(dlq_df) - dlq_malicious\n",
        "\n",
        "        total_malicious = int((df_final[\"Verdict\"] == \"MALICIOUS\").sum())\n",
        "        total_benign = total_logs - total_malicious\n",
        "        severity = (total_malicious / total_logs * 100) if total_logs > 0 else 0\n",
        "\n",
        "        # 4. START REPORT STRING\n",
        "        report = f\"\"\"FORENSIC STREAM REPORT — WINDOWS SECURITY EVENTS\n",
        "============================\n",
        "\n",
        "TOTAL LOGS\n",
        "----------------------------\n",
        "Total logs processed : {total_logs}\n",
        "\n",
        "GATEKEEPER STAGE (RandomForest)\n",
        "----------------------------\n",
        "Normal logs (Main)   : {gate_normal_count}\n",
        "Anomalous logs (DLQ) : {gate_anomaly_count}\n",
        "\n",
        "WINDOW ANALYSIS (Main Logs)\n",
        "----------------------------\n",
        "Logs analysed        : {gate_normal_count}\n",
        "Benign detected      : {main_benign}\n",
        "Malicious detected   : 0\n",
        "\n",
        "DEEP AI — MLP (DLQ Logs)\n",
        "----------------------------\n",
        "Logs analysed        : {gate_anomaly_count}\n",
        "Benign detected      : {dlq_benign}\n",
        "Malicious detected   : {dlq_malicious}\n",
        "MLP Threshold        : 95th Percentile\n",
        "\n",
        "FINAL VERDICT\n",
        "----------------------------\n",
        "Total benign         : {total_benign}\n",
        "Total malicious      : {total_malicious}\n",
        "Threat severity      : {severity:.1f}%\n",
        "\n",
        "\n",
        "\n",
        "\"\"\"\n",
        "\n",
        "        metrics_text = \"\"\n",
        "\n",
        "        try:\n",
        "            package = joblib.load(\"/content/drive/MyDrive/Colab Notebooks/windows_threat_model.pkl\")\n",
        "\n",
        "            if \"metrics\" in package:\n",
        "                m = package[\"metrics\"]\n",
        "\n",
        "                acc  = m.get(\"accuracy\", 0)\n",
        "                prec = m.get(\"precision\", 0)\n",
        "                rec  = m.get(\"recall\", 0)\n",
        "                f1   = m.get(\"f1\", 0)\n",
        "                cm   = np.array(m.get(\"confusion_matrix\", [[0,0],[0,0]]))\n",
        "\n",
        "                metrics_text = f\"\"\"\n",
        "        ============================\n",
        "        MODEL PERFORMANCE\n",
        "        ============================\n",
        "\n",
        "        Accuracy  : {acc:.4f}\n",
        "        Precision : {prec:.4f}\n",
        "        Recall    : {rec:.4f}\n",
        "        F1 Score  : {f1:.4f}\n",
        "\n",
        "        \"\"\"\n",
        "            else:\n",
        "                metrics_text = \"\\nNo stored metrics found in model file.\\n\"\n",
        "\n",
        "        except Exception as e:\n",
        "            metrics_text = f\"\\nFailed to load model metrics: {str(e)}\\n\"\n",
        "\n",
        "        report+=metrics_text\n",
        "\n",
        "        # 6. UI Outputs\n",
        "        gauge = create_gauge(severity)\n",
        "\n",
        "        if total_malicious > 0:\n",
        "            malicious_only_df = df_final[df_final[\"Verdict\"] == \"MALICIOUS\"].copy()\n",
        "            dlq_pred_dummy = np.ones(len(malicious_only_df))\n",
        "            forensic_explanation = generate_windows_forensic_explanation(malicious_only_df, dlq_pred_dummy, df_final)\n",
        "        else:\n",
        "            forensic_explanation = \"No malicious Windows logs detected.\"\n",
        "\n",
        "        return df_final, df_final, report, gauge, forensic_explanation\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        return (pd.DataFrame(), pd.DataFrame(), f\"ERROR:\\n{traceback.format_exc()}\",\n",
        "                None, \"Windows forensic pipeline crashed.\")\n",
        "# ==============================\n",
        "\n",
        "def route_logs(file_obj, log_type):\n",
        "    if file_obj is None:\n",
        "        empty_fig = create_gauge(0)\n",
        "        return pd.DataFrame(), pd.DataFrame(), \"No file uploaded.\", empty_fig, \"\"\n",
        "\n",
        "    if log_type == \"NETWORK LOGS\":\n",
        "        return process_network_logs(file_obj)\n",
        "\n",
        "    elif log_type == \"OS LOGS\":\n",
        "        return process_os_logs(file_obj)\n",
        "\n",
        "    elif log_type == \"APPLICATION LOGS\":\n",
        "        return process_application_logs(file_obj)\n",
        "\n",
        "    elif log_type == \"WINDOWS LOGS\":\n",
        "        return process_windows_logs(file_obj)\n",
        "\n",
        "    else:\n",
        "        return pd.DataFrame(), pd.DataFrame(), \"Invalid log type.\", create_gauge(0), \"\"\n",
        "\n",
        "# ==============================\n",
        "# NEW: FORENSIC EXPORT UTILITIES\n",
        "# ==============================\n",
        "\n",
        "def generate_forensic_hash(data_str):\n",
        "    \"\"\"Generates a SHA-256 hash for forensic integrity.\"\"\"\n",
        "    return hashlib.sha256(data_str.encode()).hexdigest()\n",
        "\n",
        "def export_forensic_report(df, report_text, export_type):\n",
        "    \"\"\"Handles the generation of physical files for the analyst.\"\"\"\n",
        "    if df is None or df.empty:\n",
        "        return None\n",
        "\n",
        "    timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
        "\n",
        "    if export_type == \"CSV\":\n",
        "        file_path = f\"Forensic_Evidence_{timestamp}.csv\"\n",
        "        df.to_csv(file_path, index=False)\n",
        "        return file_path\n",
        "\n",
        "    elif export_type == \"JSON\":\n",
        "        file_path = f\"STIX_Evidence_{timestamp}.json\"\n",
        "        stix_bundle = {\n",
        "            \"type\": \"bundle\",\n",
        "            \"id\": f\"bundle--{timestamp}\",\n",
        "            \"integrity_hash\": generate_forensic_hash(report_text),\n",
        "            \"objects\": df.to_dict(orient=\"records\"),\n",
        "            \"forensic_report\": report_text\n",
        "        }\n",
        "        with open(file_path, \"w\") as f:\n",
        "            json.dump(stix_bundle, f, indent=4)\n",
        "        return file_path\n",
        "\n",
        "    elif export_type == \"PDF\":\n",
        "        file_path = f\"Court_Summary_{timestamp}.txt\"\n",
        "        with open(file_path, \"w\") as f:\n",
        "            f.write(f\"OFFICIAL CYBER FORENSIC REPORT\\n\")\n",
        "            f.write(f\"Generated: {datetime.now()}\\n\")\n",
        "            f.write(f\"Integrity Hash: {generate_forensic_hash(report_text)}\\n\")\n",
        "            f.write(f\"{'='*40}\\n\\n\")\n",
        "            f.write(report_text)\n",
        "            f.write(f\"\\n\\nDATA SUMMARY:\\n\")\n",
        "            f.write(df.head(100).to_string())\n",
        "        return file_path\n",
        "\n",
        "# ==============================\n",
        "# UPDATED CSS (Deep-Space Professional)\n",
        "# ==============================\n",
        "css = \"\"\"\n",
        "body, .gradio-container { background-color: #0d1117 !important; color: #c9d1d9 !important; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important; }\n",
        ".sidebar { background-color: #161b22 !important; border-right: 1px solid #30363d !important; padding: 25px !important; }\n",
        ".main { padding: 30px !important; }\n",
        ".metric-card {\n",
        "    background: #1c2128; border: 1px solid #444c56; border-radius: 6px;\n",
        "    padding: 20px; text-align: left; transition: transform 0.2s;\n",
        "}\n",
        ".metric-val { font-size: 28px; font-weight: 600; color: #58a6ff; }\n",
        ".metric-label { font-size: 11px; text-transform: uppercase; color: #8b949e; font-weight: bold; }\n",
        ".table-container { border: 1px solid #30363d !important; border-radius: 8px !important; }\n",
        "button.primary { background-color: #238636 !important; border: none !important; }\n",
        "button.secondary { background-color: #21262d !important; border: 1px solid #30363d !important; }\n",
        "\"\"\"\n",
        "# ==============================\n",
        "# ANALYSIS WRAPPER\n",
        "# (bridges pipeline → UI outputs)\n",
        "# ==============================\n",
        "def run_analysis_wrapper(file_obj, log_type):\n",
        "    # ... (keep your existing logic) ...\n",
        "    df_display, df_full, report, gauge, explanation = route_logs(file_obj, log_type)\n",
        "\n",
        "    # IMPORTANT: Ensure the full dataset has a string-based ID for matching\n",
        "    df_full[\"__row_id\"] = [str(i) for i in range(len(df_full))]\n",
        "\n",
        "    # Filter the alerts table but keep the __row_id column\n",
        "    if \"Verdict\" in df_full.columns:\n",
        "        alerts_df = df_full[df_full[\"Verdict\"] == \"MALICIOUS\"].copy()\n",
        "    else:\n",
        "        alerts_df = df_full.copy()\n",
        "\n",
        "    # Stats for cards\n",
        "    total = len(df_full)\n",
        "    threats = len(alerts_df)\n",
        "    benign = total - threats\n",
        "    severity = round((threats / total * 100), 1) if total > 0 else 0\n",
        "\n",
        "    def card(label, val):\n",
        "        return f\"<div class='metric-card'><div class='metric-label'>{label}</div><div class='metric-val'>{val}</div></div>\"\n",
        "\n",
        "    return (\n",
        "        card(\"Log Volume\", total),\n",
        "        card(\"Threats\", threats),\n",
        "        card(\"Verified Benign\", benign),\n",
        "        card(\"Threat Index\", f\"{severity}%\"),\n",
        "        alerts_df.head(200), # Alerts table\n",
        "        df_full,              # Investigation stream\n",
        "        report,\n",
        "        explanation,\n",
        "        gauge,\n",
        "        df_full              # This goes into analysis_state\n",
        "    )\n",
        "# ==============================\n",
        "# GRADIO UI\n",
        "# ==============================\n",
        "\n",
        "css = \"\"\"\n",
        "body, .gradio-container { background-color: #0d1117 !important; color: #c9d1d9 !important; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif !important; }\n",
        ".sidebar { background-color: #161b22 !important; border-right: 1px solid #30363d !important; padding: 25px !important; }\n",
        ".main { padding: 30px !important; }\n",
        ".metric-card { background: #1c2128; border: 1px solid #444c56; border-radius: 6px; padding: 20px; text-align: left; }\n",
        ".metric-val { font-size: 28px; font-weight: 600; color: #58a6ff; }\n",
        ".metric-label { font-size: 11px; text-transform: uppercase; color: #8b949e; font-weight: bold; }\n",
        ".table-container { border: 1px solid #30363d !important; border-radius: 8px !important; }\n",
        ".inspector-panel { background: #161b22; border: 1px solid #388bfd; border-radius: 8px; padding: 16px; }\"\"\"\n",
        "\n",
        "with gr.Blocks(css=css, title=\"Forensic Command | AI SOC\") as demo:\n",
        "    analysis_state = gr.State()\n",
        "    selected_row_state = gr.State()\n",
        "    selected_log_type = gr.State(\"NETWORK LOGS\")\n",
        "\n",
        "    with gr.Row():\n",
        "        with gr.Column(scale=1, elem_classes=\"sidebar\"):\n",
        "            gr.Markdown(\"### SYSTEM HIERARCHY\")\n",
        "            nav = gr.Radio(\n",
        "                [\"Dashboard\", \"Investigation\", \"Log Inspector\", \"Forensic Reports\"],\n",
        "                value=\"Dashboard\",\n",
        "                show_label=False)\n",
        "            gr.Markdown(\"---\")\n",
        "            gr.Markdown(\"### DATA INGESTION\")\n",
        "            log_type = gr.Dropdown([\"NETWORK LOGS\", \"OS LOGS\", \"APPLICATION LOGS\", \"WINDOWS LOGS\"], value=\"NETWORK LOGS\", label=\"Schema\")\n",
        "            file_input = gr.File(label=\"Evidence Source\")\n",
        "            analyze_btn = gr.Button(\"START ANALYSIS\", variant=\"primary\")\n",
        "            gr.Markdown(\"---\")\n",
        "            gr.HTML(\"<div style='font-size:10px;color:#484f58'>LOG_LEVEL: VERBOSE<br>ENC_TYPE: AES-256<br>NODE: CORE-SOC-01</div>\")\n",
        "\n",
        "        with gr.Column(scale=5, elem_classes=\"main\"):\n",
        "            # ── PAGE: DASHBOARD ──────────────────────────────\n",
        "            with gr.Column(visible=True) as dashboard_page:\n",
        "                gr.Markdown(\"## OPERATIONS OVERVIEW\")\n",
        "                with gr.Row():\n",
        "                    m_total = gr.HTML(\"<div class='metric-card'><div class='metric-label'>Log Volume</div><div class='metric-val'>0</div></div>\")\n",
        "                    m_threats = gr.HTML(\"<div class='metric-card'><div class='metric-label'>Threats</div><div class='metric-val'>0</div></div>\")\n",
        "                    m_benign = gr.HTML(\"<div class='metric-card'><div class='metric-label'>Verified Benign</div><div class='metric-val'>0</div></div>\")\n",
        "                    m_sev = gr.HTML(\"<div class='metric-card'><div class='metric-label'>Threat Index</div><div class='metric-val'>0%</div></div>\")\n",
        "                with gr.Row():\n",
        "                    with gr.Column(scale=2):\n",
        "                        gr.Markdown(\"### High-Priority Alerts\")\n",
        "                        gr.Markdown(\"_Click any row to open Log Inspector_\", elem_id=\"hint\")\n",
        "                        alerts_table = gr.Dataframe(interactive=False, elem_classes=\"table-container\")\n",
        "                    with gr.Column(scale=1):\n",
        "                        gr.Markdown(\"### Threat Severity\")\n",
        "                        gauge_plot = gr.Plot()\n",
        "\n",
        "            # ── PAGE: INVESTIGATION ──────────────────────────\n",
        "            with gr.Column(visible=False) as investigation_page:\n",
        "                gr.Markdown(\"## EVENT STREAM ANALYSIS\")\n",
        "                gr.Markdown(\"_Click any row to open the Log Inspector_\")\n",
        "                log_stream = gr.Dataframe(label=\"Full Log Timeline\", interactive=True)\n",
        "\n",
        "            # ── PAGE: LOG INSPECTOR ──────────────────────────\n",
        "            with gr.Column(visible=False) as inspector_page:\n",
        "                gr.Markdown(\"## LOG INSPECTOR — DETAILED FORENSIC VIEW\")\n",
        "                with gr.Row():\n",
        "                    back_dashboard_btn = gr.Button(\"← Back to Dashboard\", variant=\"secondary\", scale=1)\n",
        "                    back_investigation_btn = gr.Button(\"← Back to Investigation\", variant=\"secondary\", scale=1)\n",
        "                    gr.HTML(\"<div style='flex:3'></div>\")\n",
        "\n",
        "                with gr.Row():\n",
        "                    with gr.Column(scale=1, elem_classes=\"inspector-panel\"):\n",
        "                        gr.Markdown(\"### Raw Log Fields\")\n",
        "                        raw_log_display = gr.JSON(label=\"Selected Log Record\")\n",
        "\n",
        "                    with gr.Column(scale=2):\n",
        "                        inspector_text = gr.Textbox(\n",
        "                            label=\"AI Forensic Analysis (SHAP)\",\n",
        "                            lines=28,\n",
        "                            interactive=False,\n",
        "                            placeholder=\"Select a log row from Dashboard or Investigation to inspect it here.\"\n",
        "                        )\n",
        "\n",
        "                gr.Markdown(\"### EXPORT THIS LOG\")\n",
        "                with gr.Row():\n",
        "                    exp_csv_btn = gr.Button(\"Export CSV\", variant=\"secondary\")\n",
        "                    exp_json_btn = gr.Button(\"Export STIX 2.1 JSON\", variant=\"secondary\")\n",
        "                    exp_pdf_btn = gr.Button(\"Export Court Summary (.txt)\", variant=\"secondary\")\n",
        "\n",
        "                inspector_download = gr.File(label=\"Download Export\", visible=False)\n",
        "\n",
        "            # ── PAGE: FORENSIC REPORTS ───────────────────────\n",
        "            with gr.Column(visible=False) as reports_page:\n",
        "                gr.Markdown(\"## BULK EVIDENCE EXPORT & AI FORENSICS\")\n",
        "                with gr.Row():\n",
        "                    explanation_box = gr.Textbox(lines=12, label=\"AI Explanation (SHAP) — Full Run\")\n",
        "                    report_box = gr.Textbox(lines=12, label=\"Analyst Summary — Full Run\")\n",
        "                gr.Markdown(\"### BULK EXPORT\")\n",
        "                with gr.Row():\n",
        "                    bulk_csv_btn = gr.Button(\"Export Full CSV\", variant=\"secondary\")\n",
        "                    bulk_json_btn = gr.Button(\"Export Full STIX JSON\", variant=\"secondary\")\n",
        "                    bulk_pdf_btn = gr.Button(\"Export Full Summary (.txt)\", variant=\"secondary\")\n",
        "                bulk_download = gr.File(label=\"Download\", visible=False)\n",
        "\n",
        "    # ── NAVIGATION ───────────────────────────────────────────\n",
        "    def navigate(choice):\n",
        "        return [\n",
        "            gr.update(visible=(choice == \"Dashboard\")),\n",
        "            gr.update(visible=(choice == \"Investigation\")),\n",
        "            gr.update(visible=(choice == \"Log Inspector\")),\n",
        "            gr.update(visible=(choice == \"Forensic Reports\")),\n",
        "        ]\n",
        "\n",
        "    nav.change(navigate, nav, [dashboard_page, investigation_page, inspector_page, reports_page])\n",
        "\n",
        "    back_dashboard_btn.click(\n",
        "        lambda: [gr.update(visible=True), gr.update(visible=False), gr.update(visible=False), gr.update(visible=False)],\n",
        "        outputs=[dashboard_page, investigation_page, inspector_page, reports_page]\n",
        "    )\n",
        "\n",
        "    back_investigation_btn.click(\n",
        "        lambda: [gr.update(visible=False), gr.update(visible=True), gr.update(visible=False), gr.update(visible=False)],\n",
        "        outputs=[dashboard_page, investigation_page, inspector_page, reports_page]\n",
        "    )\n",
        "\n",
        "    # ── MAIN ANALYSIS ────────────────────────────────────────\n",
        "    analyze_btn.click(\n",
        "        run_analysis_wrapper,\n",
        "        inputs=[file_input, log_type],\n",
        "        outputs=[m_total, m_threats, m_benign, m_sev,\n",
        "                 alerts_table, log_stream,\n",
        "                 report_box, explanation_box,\n",
        "                 gauge_plot, analysis_state]\n",
        "    )\n",
        "\n",
        "    log_type.change(lambda x: x, log_type, selected_log_type)\n",
        "\n",
        "    # ── ROW CLICK → LOG INSPECTOR ────────────────────────────\n",
        "    def on_row_select(evt: gr.SelectData, full_df, lt):\n",
        "        if full_df is None or full_df.empty:\n",
        "            return (gr.update(visible=True), gr.update(visible=False), gr.update(visible=False),\n",
        "                    gr.update(visible=False), {}, \"No data loaded.\", None)\n",
        "\n",
        "        try:\n",
        "            selected_idx = evt.index[0]\n",
        "            selected_row = full_df.iloc[selected_idx]\n",
        "\n",
        "            if \"__row_id\" not in full_df.columns:\n",
        "                raise ValueError(\"__row_id missing — mapping broken\")\n",
        "\n",
        "            real_id = str(selected_row[\"__row_id\"])\n",
        "            match = full_df[full_df[\"__row_id\"].astype(str) == real_id]\n",
        "\n",
        "            if match.empty:\n",
        "                raise ValueError(\"Row mapping failed — ID not found\")\n",
        "\n",
        "            row = match.iloc[0].copy()\n",
        "            row.index = [str(c).strip().lower() for c in row.index]\n",
        "\n",
        "            if lt == \"WINDOWS LOGS\":\n",
        "                row[\"verdict\"] = \"MALICIOUS\"\n",
        "                row[\"risk_score\"] = max(float(row.get(\"risk_score\", 0)), 1.0)\n",
        "\n",
        "            shap_text, prob, verdict = get_single_log_shap_explanation(row, lt, full_df)\n",
        "            raw_fields = {k: str(v) for k, v in row.items()}\n",
        "\n",
        "            return (gr.update(visible=False), gr.update(visible=False), gr.update(visible=True),\n",
        "                    gr.update(visible=False), raw_fields, shap_text, row.to_json())\n",
        "\n",
        "        except Exception as e:\n",
        "            return (gr.update(visible=False), gr.update(visible=False), gr.update(visible=True),\n",
        "                    gr.update(visible=False), {\"error\": str(e)}, \"Selection failed.\", None)\n",
        "\n",
        "    alerts_table.select(\n",
