        "\n",
        "# ==============================\n",
        "# 8. OS SHAP EXPLANATION\n",
        "# TreeExplainer — fast for RandomForest\n",
        "# ==============================\n",
        "\n",
        "def generate_os_explanation(dlq_df, dlq_pred, full_df):\n",
        "    try:\n",
        "        malicious_idx = np.where(dlq_pred == 1)[0]\n",
        "        if len(malicious_idx) == 0:\n",
        "            return \"No malicious OS logs detected — no explanation needed.\"\n",
        "\n",
        "        top_n = min(5, len(malicious_idx))\n",
        "        top_local = malicious_idx[np.argsort(\n",
        "            # sort by highest risk first using RF proba if available, else just take first 5\n",
        "            [os_model.predict_proba(\n",
        "                dlq_df[os_features].fillna(0).iloc[[i]]\n",
        "            )[:, 1][0] for i in malicious_idx]\n",
        "        )[::-1][:top_n]]\n",
        "        top_global = dlq_df.index[top_local]\n",
        "\n",
        "        X_explain = dlq_df[os_features].fillna(0).iloc[top_local]\n",
        "        explainer = shap.TreeExplainer(os_model)\n",
        "        shap_values = explainer.shap_values(X_explain)\n",
        "\n",
        "        if isinstance(shap_values, list):\n",
        "            sv_matrix = shap_values[1]\n",
        "        else:\n",
        "            sv_matrix = shap_values\n",
        "\n",
        "        probs_explain = os_model.predict_proba(X_explain)[:, 1]\n",
        "\n",
        "        text = \"=\" * 60 + \"\\n\"\n",
        "        text += \"  AI FORENSIC EXPLANATION — TOP SUSPICIOUS OS LOGS\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\\n\"\n",
        "\n",
        "        all_os_contexts = []\n",
        "\n",
        "        for rank, (local_i, global_i) in enumerate(zip(range(top_n), top_global)):\n",
        "            prob_val = probs_explain[local_i]\n",
        "            row_data = full_df.loc[global_i]\n",
        "            row_dict = dlq_df.loc[global_i].to_dict()\n",
        "\n",
        "            text += f\"LOG #{rank+1}  —  Threat Confidence: {prob_val:.1%}\\n\"\n",
        "            text += \"-\" * 50 + \"\\n\"\n",
        "            for field, label in [\n",
        "                (\"_source.agent.name\", \"Agent\"),\n",
        "                (\"_source.agent.ip\", \"Agent IP\"),\n",
        "                (\"_source.data.audit.exe\", \"Executable\"),\n",
        "                (\"executed_command\", \"Command\"),\n",
        "                (\"effective_uid\", \"Effective UID\"),\n",
        "                (\"_source.rule.level\", \"Rule Level\"),\n",
        "            ]:\n",
        "                if field in full_df.columns:\n",
        "                    val = row_data.get(field, \"N/A\")\n",
        "                    # Decode UID for display\n",
        "                    if field == \"effective_uid\":\n",
        "                        val_str = f\"{val} (root)\" if str(val) == \"0\" else str(val)\n",
        "                    elif field == \"_source.rule.level\":\n",
        "                        try:\n",
        "                            lvl = int(float(val))\n",
        "                            val_str = f\"{val} — {RULE_LEVEL_MAP.get(min(lvl,15), '')}\"\n",
        "                        except (ValueError, TypeError):\n",
        "                            val_str = str(val)\n",
        "                    else:\n",
        "                        val_str = str(val)\n",
        "                    text += f\"  {label:<18}: {val_str}\\n\"\n",
        "            text += \"\\n\"\n",
        "\n",
        "            sv = sv_matrix[local_i]\n",
        "            if isinstance(sv[0], (list, np.ndarray)):\n",
        "                sv = sv[:, 1]\n",
        "            sv = np.array(sv).flatten()\n",
        "\n",
        "            contributions = sorted(\n",
        "                zip(os_features, sv),\n",
        "                key=lambda x: abs(float(x[1])),\n",
        "                reverse=True\n",
        "            )[:5]\n",
        "\n",
        "            text += \"  Top Contributing Features (SHAP):\\n\"\n",
        "            for feat, impact in contributions:\n",
        "                direction = \"↑ increased\" if impact > 0 else \"↓ reduced\"\n",
        "                val = dlq_df.loc[global_i, feat] if feat in dlq_df.columns else 0\n",
        "                bar = \"█\" * int(min(abs(impact) * 1000, 20))\n",
        "                desc = OS_FEATURE_DESCRIPTIONS.get(feat, \"\")\n",
        "                text += (f\"    • {feat[-30:]:<30} = {float(val):>10.4f}  \"\n",
        "                         f\"→ {direction} threat  (SHAP: {impact:+.4f}) {bar}\\n\")\n",
        "                if desc:\n",
        "                    text += f\"       ↳ {desc}\\n\"\n",
        "\n",
        "            text += \"\\n  AI FORENSIC NARRATIVE (Groq / LLaMA-3.3-70B):\\n\"\n",
        "            text += \"  \" + \"-\" * 48 + \"\\n\"\n",
        "\n",
        "            max_shap = max(abs(imp) for _, imp in contributions) if contributions else 0\n",
        "            if max_shap < 0.001 and prob_val < 0.50:\n",
        "                text += f\"  Low-confidence flag (max |SHAP| = {max_shap:.5f}).\\n\"\n",
        "                text += f\"  No single feature drove this alert — likely false positive.\\n\"\n",
        "            else:\n",
        "                raw_row = full_df.loc[global_i].to_dict() if global_i in full_df.index else {}\n",
        "                llm_text = get_llm_os_narrative(row_dict, contributions, prob_val, raw_row)\n",
        "                for line in llm_text.split(\"\\n\"):\n",
        "                    text += f\"  {line}\\n\"\n",
        "            text += \"\\n\"\n",
        "\n",
        "            all_os_contexts.append(decode_os_log_context(row_dict, full_df.loc[global_i].to_dict()\n",
        "                                   if global_i in full_df.index else {}))\n",
        "\n",
        "        # Cross-log pattern summary\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        text += \"  CROSS-LOG PATTERN ANALYSIS (Threat Hunter View)\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        pattern_text = get_llm_os_pattern_summary(all_os_contexts)\n",
        "        for line in pattern_text.split(\"\\n\"):\n",
        "            text += f\"  {line}\\n\"\n",
        "        text += \"\\n\"\n",
        "\n",
        "        total_malicious = int((dlq_pred == 1).sum())\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        text += f\"  BATCH SUMMARY: {total_malicious} malicious OS logs in DLQ.\\n\"\n",
        "        text += f\"  Full LLM analysis shown for top {top_n} highest-confidence alerts.\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "\n",
        "        return text\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        return f\"OS explanation error:\\n{traceback.format_exc()}\"\n",
        "\n",
        "\n",
        "\n",
        "#----------------------\n",
        "#Windows Explanation\n",
        "#----------------------\n",
        "\n",
        "\n",
        "\n",
        "def get_single_log_shap_explanation(row_series, log_type, full_df_state):\n",
        "    try:\n",
        "        row_df = pd.DataFrame([row_series])\n",
        "\n",
        "        if log_type == \"NETWORK LOGS\":\n",
        "            row_df = preprocess_network_logs(row_df)\n",
        "            for col in net_mlp_features:\n",
        "                if col not in row_df.columns:\n",
        "                    row_df[col] = 0\n",
        "\n",
        "            X = row_df[net_mlp_features].fillna(0).astype(np.float32)\n",
        "            X_scaled = net_scaler.transform(X)\n",
        "            X_clipped = np.clip(X_scaled, -10, 10)\n",
        "\n",
        "            mlp_p = net_model.predict(X_clipped, verbose=0).flatten()[0]\n",
        "            xgb_p = xgb_model.predict_proba(X_clipped)[:, 1][0]\n",
        "            lgbm_p = lgbm_model.predict_proba(X_clipped)[:, 1][0]\n",
        "            prob = (mlp_p + xgb_p + lgbm_p) / 3\n",
        "\n",
        "            inspector_threshold = max(ens_threshold, 0.50)\n",
        "            verdict = \"MALICIOUS\" if prob >= inspector_threshold else \"BENIGN\"\n",
        "\n",
        "            background = X_clipped\n",
        "            explainer = shap.KernelExplainer(\n",
        "                lambda x: net_model.predict(x, verbose=0).flatten(), background\n",
        "            )\n",
        "            shap_values = explainer.shap_values(X_clipped, nsamples=50)\n",
        "            sv = shap_values[0] if isinstance(shap_values, list) else shap_values[0]\n",
        "\n",
        "            contributions = sorted(\n",
        "                zip(net_mlp_features, sv), key=lambda x: abs(x[1]), reverse=True\n",
        "            )[:8]\n",
        "\n",
        "            text = f\"LOG INSPECTOR — NETWORK LOG\\n\"\n",
        "            text += f\"{'='*55}\\n\"\n",
        "            text += f\"Verdict          : {verdict}\\n\"\n",
        "            text += f\"Threat Confidence: {prob:.1%}  \"\n",
        "            text += f\"(MLP:{mlp_p:.2f} | XGB:{xgb_p:.2f} | LGBM:{lgbm_p:.2f})\\n\"\n",
        "\n",
        "            text += f\"\\nKEY IDENTIFIERS\\n{'-'*40}\\n\"\n",
        "            for field in ['IPV4_SRC_ADDR','IPV4_DST_ADDR','L4_DST_PORT','PROTOCOL','L7_PROTO']:\n",
        "                if field in row_series.index:\n",
        "                    text += f\"  {field:<25}: {row_series[field]}\\n\"\n",
        "\n",
        "            text += f\"\\nTOP SHAP FEATURE CONTRIBUTIONS\\n{'-'*40}\\n\"\n",
        "            for feat, impact in contributions:\n",
        "                direction = \"↑ THREAT\" if impact > 0 else \"↓ benign\"\n",
        "                val = row_df[feat].values[0] if feat in row_df.columns else 0\n",
        "                bar = \"█\" * int(min(abs(impact) * 1000, 20))\n",
        "                desc = FEATURE_DESCRIPTIONS.get(feat, \"\")\n",
        "                text += f\"  {feat:<28} {float(val):>10.3f}  {direction}  {bar} ({impact:+.4f})\\n\"\n",
        "                text += f\"     ↳ {desc}\\n\"\n",
        "\n",
        "            text += f\"\\nAI FORENSIC NARRATIVE (Groq / LLaMA-3.3-70B)\\n{'-'*40}\\n\"\n",
        "\n",
        "            if verdict == \"BENIGN\":\n",
        "                text += f\"  Log classified BENIGN ({prob:.1%} confidence).\\n\"\n",
        "                text += f\"  No forensic investigation required.\\n\"\n",
        "                text += f\"  Cleared by ensemble model — no action needed.\\n\"\n",
        "            else:\n",
        "                max_shap = max(abs(impact) for _, impact in contributions[:5]) if contributions else 0\n",
        "\n",
        "                if max_shap < 0.001 and prob < 0.50:\n",
        "                    text += f\"  Confidence: {prob:.1%} — weak signal, below reliable threshold.\\n\"\n",
        "                    text += f\"  SHAP explanation: No single feature drove this flag \"\n",
        "                    text += f\"(max |SHAP| = {max_shap:.5f}).\\n\"\n",
        "                    text += f\"  Assessment: Likely false positive. The model detected a subtle\\n\"\n",
        "                    text += f\"  pattern combination not visible in the top contributors.\\n\"\n",
        "                    text += f\"  No immediate action recommended.\\n\"\n",
        "                else:\n",
        "                    row_dict = row_series.to_dict()\n",
        "                    llm_text = get_llm_forensic_narrative(\n",
        "                        row_dict, contributions[:5], prob, \"Network Log\"\n",
        "                    )\n",
        "                    for line in llm_text.split(\"\\n\"):\n",
        "                        text += f\"  {line}\\n\"\n",
        "\n",
        "            text += f\"\\nRECOMMENDED ACTION\\n{'-'*40}\\n\"\n",
        "            if verdict == \"BENIGN\":\n",
        "                text += \"  ✓  BENIGN   — Log cleared. No action required.\\n\"\n",
        "            elif prob > 0.85:\n",
        "                text += \"  ⚠  CRITICAL — Isolate source IP immediately. Analyst review required.\\n\"\n",
        "            elif prob > 0.65:\n",
        "                text += \"  ⚡ HIGH     — Correlate with surrounding telemetry. Validate attack pattern.\\n\"\n",
        "            elif prob > 0.40:\n",
        "                text += \"  ℹ  MEDIUM   — Monitor for persistence. Correlate with other logs from this host.\\n\"\n",
        "            else:\n",
        "                text += \"  ~  LOW      — Weak signal. Likely false positive. No immediate action required.\\n\"\n",
        "\n",
        "            return text, prob, verdict\n",
        "\n",
        "        elif log_type == \"WINDOWS LOGS\":\n",
        "            if row_series is None or len(row_series) == 0:\n",
        "                return \"No log selected\", 0.0, \"ERROR\"\n",
        "\n",
        "            if isinstance(row_series, dict):\n",
        "                row_series = pd.Series(row_series)\n",
        "\n",
        "            row_series.index = [str(c).strip().lower() for c in row_series.index]\n",
        "\n",
        "            date_val = row_series.get(\"date_and_time\") or row_series.get(\"date\")\n",
        "            event_val = row_series.get(\"event_id\")\n",
        "\n",
        "            if date_val is None or event_val is None:\n",
        "                return (\n",
        "                    \"⚠ Missing key fields (date/event_id). Cannot map to ML output.\",\n",
        "                    0.0,\n",
        "                    \"ERROR\"\n",
        "                )\n",
        "\n",
        "            risk_score = float(row_series.get(\"risk_score\", 0.0))\n",
        "            verdict = str(row_series.get(\"verdict\", row_series.get(\"Verdict\", \"UNKNOWN\"))).upper()\n",
        "\n",
        "            if risk_score >= 1:\n",
        "                verdict = \"MALICIOUS\"\n",
        "\n",
        "            text = \"LOG INSPECTOR — WINDOWS LOG\\n\"\n",
        "            text += \"=\" * 55 + \"\\n\\n\"\n",
        "\n",
        "            important_fields = [\n",
        "                \"date_and_time\", \"event_id\", \"source\", \"task_category\",\n",
        "                \"message\", \"event_freq\", \"burst_count\", \"risk_score\"\n",
        "            ]\n",
        "\n",
        "            for col in important_fields:\n",
        "                if col in row_series.index:\n",
        "                    text += f\"{col:<20}: {row_series[col]}\\n\"\n",
        "\n",
        "            text += \"\\nAI FORENSIC ANALYSIS\\n\"\n",
        "            text += \"-\" * 40 + \"\\n\"\n",
        "\n",
        "            try:\n",
        "                llm_text = get_llm_windows_narrative(row_series.to_dict())\n",
        "            except Exception as e:\n",
        "                llm_text = f\"LLM unavailable: {e}\"\n",
        "\n",
        "            text += llm_text\n",
        "            return text, risk_score, verdict\n",
        "\n",
        "        elif log_type == \"OS LOGS\":\n",
        "            row_df = preprocess_os_logs(row_df)\n",
        "            for col in os_features:\n",
        "                if col not in row_df.columns:\n",
        "                    row_df[col] = 0\n",
        "\n",
        "            X = row_df[os_features].fillna(0)\n",
        "            prob = os_model.predict_proba(X)[:, 1][0]\n",
        "            verdict = \"MALICIOUS\" if prob >= 0.50 else \"BENIGN\"\n",
        "\n",
        "            explainer = shap.TreeExplainer(os_model)\n",
        "            shap_values = explainer.shap_values(X)\n",
        "            sv = shap_values[1][0] if isinstance(shap_values, list) else shap_values[0]\n",
        "\n",
        "            contributions = sorted(\n",
        "                zip(os_features, sv.tolist()), key=lambda x: abs(x[1]), reverse=True\n",
        "            )[:8]\n",
        "\n",
        "            text = f\"LOG INSPECTOR — OS LOG\\n{'='*55}\\n\"\n",
        "            text += f\"Verdict          : {verdict}\\n\"\n",
        "            text += f\"Threat Confidence: {prob:.1%}\\n\"\n",
        "\n",
        "            text += f\"\\nKEY IDENTIFIERS\\n{'-'*40}\\n\"\n",
        "            for field, label in [\n",
        "                (\"_source.agent.name\", \"Agent\"),\n",
        "                (\"_source.agent.ip\",   \"Agent IP\"),\n",
        "                (\"_source.data.audit.exe\", \"Executable\"),\n",
        "                (\"executed_command\",   \"Command\"),\n",
        "                (\"effective_uid\",      \"Effective UID\"),\n",
        "                (\"_source.rule.level\", \"Rule Level\"),\n",
        "            ]:\n",
        "                if field in row_series.index:\n",
        "                    val = row_series[field]\n",
        "                    if field == \"effective_uid\":\n",
        "                        val = f\"{val} (root)\" if str(val) == \"0\" else str(val)\n",
        "                    elif field == \"_source.rule.level\":\n",
        "                        try:\n",
        "                            lvl = int(float(val))\n",
        "                            val = f\"{val} — {RULE_LEVEL_MAP.get(min(lvl,15), '')}\"\n",
        "                        except (ValueError, TypeError):\n",
        "                            pass\n",
        "                    text += f\"  {label:<18}: {val}\\n\"\n",
        "\n",
        "            text += f\"\\nTOP SHAP FEATURE CONTRIBUTIONS\\n{'-'*40}\\n\"\n",
        "            for feat, impact in contributions:\n",
        "                direction = \"↑ THREAT\" if impact > 0 else \"↓ benign\"\n",
        "                val = row_df[feat].values[0] if feat in row_df.columns else 0\n",
        "                bar = \"█\" * int(min(abs(impact) * 1000, 20))\n",
        "                desc = OS_FEATURE_DESCRIPTIONS.get(feat, \"\")\n",
        "                text += f\"  {feat[-28:]:<28} {float(val):>10.3f}  {direction}  {bar} ({impact:+.4f})\\n\"\n",
        "                if desc:\n",
        "                    text += f\"     ↳ {desc}\\n\"\n",
        "\n",
        "            text += f\"\\nAI FORENSIC NARRATIVE (Groq / LLaMA-3.3-70B)\\n{'-'*40}\\n\"\n",
        "\n",
        "            if verdict == \"BENIGN\":\n",
        "                text += f\"  Log classified BENIGN ({prob:.1%} confidence).\\n\"\n",
        "                text += f\"  No forensic investigation required.\\n\"\n",
        "            else:\n",
        "                max_shap = max(abs(imp) for _, imp in contributions[:5]) if contributions else 0\n",
        "                if max_shap < 0.001 and prob < 0.50:\n",
        "                    text += f\"  Confidence: {prob:.1%} — weak signal (max |SHAP| = {max_shap:.5f}).\\n\"\n",
        "                    text += f\"  Likely false positive. No immediate action recommended.\\n\"\n",
        "                else:\n",
        "                    row_dict = row_df.iloc[0].to_dict()\n",
        "                    raw_row_dict = row_series.to_dict()\n",
        "                    llm_text = get_llm_os_narrative(\n",
        "                        row_dict, contributions[:5], prob, raw_row_dict\n",
        "                    )\n",
        "                    for line in llm_text.split(\"\\n\"):\n",
        "                        text += f\"  {line}\\n\"\n",
        "\n",
        "            text += f\"\\nRECOMMENDED ACTION\\n{'-'*40}\\n\"\n",
        "            if verdict == \"BENIGN\":\n",
        "                text += \"  ✓  BENIGN   — Log cleared. No action required.\\n\"\n",
        "            elif prob > 0.85:\n",
        "                text += \"  ⚠  CRITICAL — Isolate host immediately. Check process tree and file changes.\\n\"\n",
        "            elif prob > 0.65:\n",
        "                text += \"  ⚡ HIGH     — Review audit trail. Correlate with network logs.\\n\"\n",
        "            elif prob > 0.40:\n",
        "                text += \"  ℹ  MEDIUM   — Monitor this host for further suspicious activity.\\n\"\n",
        "            else:\n",
        "                text += \"  ~  LOW      — Weak signal. Likely false positive.\\n\"\n",
        "\n",
        "            return text, prob, verdict\n",
        "\n",
        "        elif log_type == \"APPLICATION LOGS\":\n",
        "              # ============================================================\n",
        "              # COMPLETE LOG INSPECTOR FOR APPLICATION LOGS\n",
        "              # ============================================================\n",
        "\n",
        "              # Preprocess the single row\n",
        "              row_df = pd.DataFrame([row_series])\n",
        "\n",
        "              # Use the same preprocessing as the main pipeline\n",
        "              X_processed = preprocess_application_logs(row_df)\n",
        "\n",
        "              # Ensure all expected features exist\n",
        "              expected_features = app_gatekeeper_model.feature_names_in_\n",
        "              for col in expected_features:\n",
        "                  if col not in X_processed.columns:\n",
        "                      X_processed[col] = 0\n",
        "\n",
        "              # Reorder columns to match model\n",
        "              X = X_processed[expected_features].fillna(0).astype(np.float32)\n",
        "\n",
        "              # Get prediction\n",
        "              prob = app_gatekeeper_model.predict_proba(X)[:, 1][0]\n",
        "              verdict = \"MALICIOUS\" if prob >= app_threshold else \"BENIGN\"\n",
        "\n",
        "              # Calculate SHAP values\n",
        "              try:\n",
        "                  explainer = shap.TreeExplainer(app_gatekeeper_model)\n",
        "                  shap_values = explainer.shap_values(X)\n",
        "\n",
        "                  # Handle binary classification output\n",
        "                  if isinstance(shap_values, list):\n",
        "                      sv = shap_values[1][0] if len(shap_values) > 1 else shap_values[0][0]\n",
        "                  else:\n",
        "                      sv = shap_values[0]\n",
        "\n",
        "                  contributions = sorted(\n",
        "                      zip(expected_features, sv),\n",
        "                      key=lambda x: abs(x[1]),\n",
        "                      reverse=True\n",
        "                  )[:10]\n",
        "\n",
        "              except Exception as e:\n",
        "                  print(f\"SHAP error for app log: {e}\")\n",
        "                  contributions = []\n",
        "\n",
        "              # Build inspector output\n",
        "              text = \"LOG INSPECTOR — APPLICATION LOG\\n\"\n",
        "              text += \"=\" * 60 + \"\\n\"\n",
        "              text += f\"Verdict          : {verdict}\\n\"\n",
        "              text += f\"Threat Confidence: {prob:.1%}\\n\"\n",
        "              text += f\"Threshold used   : {app_threshold:.3f}\\n\"\n",
        "\n",
        "              # KEY IDENTIFIERS\n",
        "              text += f\"\\n📋 KEY IDENTIFIERS\\n\"\n",
        "              text += \"-\" * 40 + \"\\n\"\n",
        "\n",
        "              # Display all important fields from the raw log\n",
        "              important_fields = {\n",
        "                  'request_path': 'Request Path',\n",
        "                  'method': 'HTTP Method',\n",
        "                  'src_ip': 'Source IP',\n",
        "                  'source_ip': 'Source IP',\n",
        "                  'status_code': 'Status Code',\n",
        "                  'response_code': 'Status Code',\n",
        "                  'user_agent': 'User-Agent',\n",
        "                  'protocol': 'Protocol',\n",
        "                  'action': 'Action',\n",
        "                  'log_type': 'Log Type',\n",
        "                  'bytes_transferred': 'Bytes',\n",
        "                  'timestamp': 'Timestamp'\n",
        "              }\n",
        "\n",
        "              for field, label in important_fields.items():\n",
        "                  if field in row_series.index:\n",
        "                      val = str(row_series[field])[:100]\n",
        "                      text += f\"  {label:<18}: {val}\\n\"\n",
        "\n",
        "              # TOP SHAP FEATURE CONTRIBUTIONS\n",
        "              text += f\"\\n🎯 TOP SHAP FEATURE CONTRIBUTIONS\\n\"\n",
        "              text += \"-\" * 40 + \"\\n\"\n",
        "\n",
        "              if contributions:\n",
        "                  for feat, impact in contributions[:8]:\n",
        "                      direction = \"🔴 INCREASES threat\" if impact > 0 else \"🟢 DECREASES threat\"\n",
        "                      # Get the actual value\n",
        "                      if feat in X.columns:\n",
        "                          val = X[feat].values[0]\n",
        "                      elif feat in row_series.index:\n",
        "                          val = row_series[feat]\n",
        "                      else:\n",
        "                          val = 0\n",
        "\n",
        "                      bar = \"█\" * int(min(abs(impact) * 100, 30))\n",
        "                      desc = APP_FEATURE_DESCRIPTIONS.get(feat, \"\")\n",
        "\n",
        "                      text += f\"\\n  📊 {feat:<30} = {float(val):>10.4f}\\n\"\n",
        "                      text += f\"     {direction} (SHAP: {impact:+.4f}) {bar}\\n\"\n",
        "                      if desc:\n",
        "                          text += f\"     📝 {desc}\\n\"\n",
        "              else:\n",
        "                  text += \"  No SHAP contributions available\\n\"\n",
        "\n",
        "              # AI FORENSIC NARRATIVE (Groq LLM)\n",
        "              text += f\"\\n🤖 AI FORENSIC NARRATIVE (Groq / LLaMA-3.3-70B)\\n\"\n",
        "              text += \"-\" * 40 + \"\\n\"\n",
        "\n",
        "              if verdict == \"BENIGN\":\n",
        "                  text += f\"  ✓ Log classified BENIGN ({prob:.1%} confidence).\\n\"\n",
        "                  text += f\"  No forensic investigation required.\\n\"\n",
        "                  text += f\"  The request appears to be normal web traffic.\\n\"\n",
        "              else:\n",
        "                  max_shap = max(abs(imp) for _, imp in contributions[:5]) if contributions else 0\n",
        "                  if max_shap < 0.001 and prob < 0.50:\n",
        "                      text += f\"  ⚠ Confidence: {prob:.1%} — weak signal (max |SHAP| = {max_shap:.5f}).\\n\"\n",
        "                      text += f\"  Likely false positive. Review the request path for anomalies.\\n\"\n",
        "                  else:\n",
        "                      row_dict = row_series.to_dict()\n",
        "                      llm_text = get_llm_app_narrative(row_dict, contributions[:5], prob)\n",
        "                      for line in llm_text.split(\"\\n\"):\n",
        "                          text += f\"  {line}\\n\"\n",
        "\n",
        "              # RECOMMENDED ACTION\n",
        "              text += f\"\\n🛡️ RECOMMENDED ACTION\\n\"\n",
        "              text += \"-\" * 40 + \"\\n\"\n",
        "\n",
        "              if verdict == \"BENIGN\":\n",
        "                  text += \"  ✓ BENIGN — Log cleared. No action required.\\n\"\n",
        "              elif prob > 0.85:\n",
        "                  text += \"  🔴 CRITICAL — Block source IP immediately!\\n\"\n",
        "                  text += \"     • Add WAF rule to block similar patterns\\n\"\n",
        "                  text += \"     • Investigate for successful exploitation\\n\"\n",
        "                  text += \"     • Check server logs for lateral movement\\n\"\n",
        "              elif prob > 0.65:\n",
        "                  text += \"  🟠 HIGH — Urgent investigation required\\n\"\n",
        "                  text += \"     • Correlate with other requests from this IP\\n\"\n",
        "                  text += \"     • Review server access logs\\n\"\n",
        "                  text += \"     • Consider temporary IP block\\n\"\n",
        "              elif prob > 0.40:\n",
        "                  text += \"  🟡 MEDIUM — Monitor closely\\n\"\n",
        "                  text += \"     • Watch for repeated attempts\\n\"\n",
        "                  text += \"     • Log for future correlation\\n\"\n",
        "              else:\n",
        "                  text += \"  🟢 LOW — No immediate action needed\\n\"\n",
        "                  text += \"     • Continue normal monitoring\\n\"\n",
        "\n",
        "              text += \"\\n\" + \"=\" * 60 + \"\\n\"\n",
        "              text += \"  Log Inspector Complete — Full forensic analysis above\\n\"\n",
        "              text += \"=\" * 60\n",
        "\n",
        "              return text, prob, verdict\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        return f\"Inspector error:\\n{traceback.format_exc()}\", 0.0, \"ERROR\"\n",
        "# ==============================\n",
        "# SINGLE LOG EXPORT\n",
        "# ==============================\n",
        "\n",
        "def export_single_log_report(row_json_str, shap_text, export_format):\n",
        "    \"\"\"\n",
        "    Exports the selected log + SHAP analysis as CSV / JSON / TXT(PDF-style).\n",
        "    row_json_str : the selected row stored as JSON string in gr.State\n",
        "    shap_text    : the inspector textbox content\n",
        "    export_format: \"CSV\", \"JSON\", or \"PDF\"\n",
        "    \"\"\"\n",
        "    try:\n",
        "        if not row_json_str:\n",
        "            return None\n",
        "\n",
        "        row_dict = json.loads(row_json_str)\n",
        "        timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
        "        integrity = hashlib.sha256(shap_text.encode()).hexdigest()\n",
        "\n",
        "        if export_format == \"CSV\":\n",
        "            path = f\"LogInspector_Evidence_{timestamp}.csv\"\n",
        "            pd.DataFrame([row_dict]).to_csv(path, index=False)\n",
        "            return path\n",
        "\n",
        "        elif export_format == \"JSON\":\n",
        "            path = f\"LogInspector_STIX_{timestamp}.json\"\n",
        "            bundle = {\n",
        "                \"type\": \"bundle\",\n",
        "                \"id\": f\"bundle--{timestamp}\",\n",
        "                \"integrity_hash\": integrity,\n",
        "                \"generated\": str(datetime.now()),\n",
        "                \"log_record\": row_dict,\n",
        "                \"ai_forensic_analysis\": shap_text\n",
        "            }\n",
        "            with open(path, \"w\") as f:\n",
        "                json.dump(bundle, f, indent=4)\n",
        "            return path\n",
        "\n",
        "        elif export_format == \"PDF\":\n",
        "            path = f\"LogInspector_CourtSummary_{timestamp}.txt\"\n",
        "            with open(path, \"w\") as f:\n",
        "                f.write(\"=\" * 60 + \"\\n\")\n",
        "                f.write(\"OFFICIAL CYBER FORENSIC LOG REPORT\\n\")\n",
        "                f.write(f\"Generated     : {datetime.now()}\\n\")\n",
        "                f.write(f\"Integrity Hash: {integrity}\\n\")\n",
        "                f.write(\"=\" * 60 + \"\\n\\n\")\n",
        "                f.write(\"RAW LOG RECORD\\n\")\n",
        "                f.write(\"-\" * 40 + \"\\n\")\n",
        "                for k, v in row_dict.items():\n",
        "                    f.write(f\"  {k:<35}: {v}\\n\")\n",
        "                f.write(\"\\n\\nAI FORENSIC ANALYSIS\\n\")\n",
        "                f.write(\"-\" * 40 + \"\\n\")\n",
        "                f.write(shap_text)\n",
        "            return path\n",
        "\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        print(traceback.format_exc())\n",
        "        return None\n",
        "\n",
        "def process_network_logs(file_obj):\n",
        "    try:\n",
        "        # 1. Load and Preprocess\n",
        "        df = pd.read_csv(file_obj.name)\n",
        "        df = preprocess_network_logs(df)\n",
        "\n",
        "        for col in net_mlp_features + net_trained_features:\n",
        "            if col not in df.columns:\n",
        "                df[col] = 0\n",
        "\n",
        "        # ==============================\n",
        "        # STAGE 1: GATEKEEPER (RandomForest)\n",
        "        # ==============================\n",
        "        X_gate = df.reindex(columns=net_trained_features, fill_value=0)\n",
        "\n",
        "        # Replace inf with nan\n",
        "        X_gate = X_gate.replace([np.inf, -np.inf], np.nan)\n",
        "\n",
        "        # Replace NaN with 0\n",
        "        X_gate = X_gate.fillna(0)\n",
        "\n",
        "        # Clip extremely large values\n",
        "        X_gate = X_gate.clip(-1e10, 1e10)\n",
        "\n",
        "        # Convert safely to float32\n",
        "        X_gate = X_gate.astype(np.float32)\n",
        "\n",
        "# =============================\n",
        "# PREDICTION & PIPELINE\n",
        "# =============================\n",
        "\n",
        "        # Using the RF Gatekeeper probabilities\n",
        "        gate_probs = net_gatekeeper_pkg['model'].predict_proba(X_gate)[:, 1]\n",
        "        gate_threshold = net_gatekeeper_pkg['threshold']\n",
        "\n",
        "        is_anomalous = pd.Series(gate_probs >= gate_threshold, index=df.index)\n",
        "        is_normal = ~is_anomalous\n",
        "\n",
        "        gate_normal_count = int(is_normal.sum())\n",
        "        gate_anomaly_count = int(is_anomalous.sum())\n",
        "\n",
        "        main_df = df[is_normal].copy()\n",
        "        dlq_df = df[is_anomalous].copy()\n",
        "\n",
        "        # ==============================\n",
        "        # STAGE 2: WINDOW ANALYSIS (Main Logs)\n",
        "        # ==============================\n",
        "        main_pred = network_window_analysis(main_df)\n",
        "        window_malicious = int((main_pred == 1).sum())\n",
        "        window_benign = int((main_pred == 0).sum())\n",
        "\n",
        "        # ==============================\n",
        "        # STAGE 3: ULTRA-PRECISION ADJUDICATION (DLQ Logs)\n",
        "        # ==============================\n",
        "        # Re-tuned for 99%+ Accuracy by balancing Precision and Recall\n",
        "        use_threshold = 0.60\n",
        "        probs = np.array([])\n",
        "        dlq_pred = np.array([])\n",
        "\n",
        "        if len(dlq_df) > 0:\n",
        "            X_mlp = dlq_df[net_mlp_features].fillna(0).astype(np.float32)\n",
        "            X_scaled = net_scaler.transform(X_mlp)\n",
        "\n",
        "            # Focused clipping to remove sensor noise and extreme spikes\n",
        "            X_clipped = np.clip(X_scaled, -4, 4)\n",
        "\n",
        "            # Base Model Inference\n",
        "            mlp_p = net_model.predict(X_clipped, verbose=0).flatten()\n",
        "            xgb_p = xgb_model.predict_proba(X_clipped)[:, 1]\n",
        "            lgbm_p = lgbm_model.predict_proba(X_clipped)[:, 1]\n",
        "\n",
        "            # 1. Consensus & Stability Analysis\n",
        "            consensus_val = (mlp_p + xgb_p + lgbm_p) / 3\n",
        "            # Detect if sub-models are \"arguing\"\n",
        "            variance = np.var([mlp_p, xgb_p, lgbm_p], axis=0)\n",
        "\n",
        "            meta_feats = np.column_stack([\n",
        "                xgb_p, lgbm_p, mlp_p,\n",
        "                np.maximum(xgb_p, lgbm_p),\n",
        "                np.maximum(xgb_p, mlp_p),\n",
        "                np.maximum(lgbm_p, mlp_p),\n",
        "                consensus_val,\n",
        "                np.abs(xgb_p - mlp_p),\n",
        "                np.abs(lgbm_p - mlp_p),\n",
        "            ])\n",
        "\n",
        "            meta_raw = meta_model.predict_proba(meta_feats)[:, 1]\n",
        "            probs = meta_raw * (1 - (0.5 * variance))\n",
        "\n",
        "            override = (\n",
        "                (dlq_df[\"RETRANS_RATIO_IN\"].fillna(0) > 0.92) |\n",
        "                (dlq_df[\"RETRANS_RATIO_OUT\"].fillna(0) > 0.92) |\n",
        "                (dlq_df[\"BYTE_RATIO\"].fillna(0) > 485) |\n",
        "                (dlq_df[\"PKTS_PER_MS\"].fillna(0) > 30)\n",
        "            ).values\n",
        "\n",
        "            burst_override = (\n",
        "                (dlq_df[\"TOTAL_PKTS\"].fillna(0) > 2000) &\n",
        "                (dlq_df[\"FLOW_DURATION_MILLISECONDS\"].fillna(1) < 100)\n",
        "            ).values\n",
        "\n",
        "            override = override | burst_override\n",
        "\n",
        "            # 5. Final Verdict logic\n",
        "            dlq_pred = np.zeros(len(probs))\n",
        "            dlq_pred[probs >= use_threshold] = 1\n",
        "            dlq_pred[probs < 0.25] = 0\n",
        "\n",
        "            # Reduces false positives\n",
        "            benign_override = (\n",
        "                (dlq_df[\"PKTS_PER_MS\"].fillna(0) < 4) &\n",
        "                (dlq_df[\"RETRANS_RATIO_IN\"].fillna(0) < 0.05) &\n",
        "                (dlq_df[\"RETRANS_RATIO_OUT\"].fillna(0) < 0.05) &\n",
        "                (dlq_df[\"TTL_DIFF\"].fillna(0) < 35) &\n",
        "                (probs < 0.65)\n",
        "            ).values\n",
        "\n",
        "            dlq_pred[benign_override] = 0\n",
        "            uncertain = (probs >= 0.25) & (probs < use_threshold)\n",
        "\n",
        "            vote_consensus = (\n",
        "                (mlp_p > 0.5).astype(int) +\n",
        "                (xgb_p > 0.5).astype(int) +\n",
        "                (lgbm_p > 0.5).astype(int)\n",
        "            )\n",
        "\n",
        "            dlq_pred[uncertain & (vote_consensus >= 2)] = 1\n",
        "            dlq_pred[override] = 1\n",
        "\n",
        "            mlp_malicious = int((dlq_pred == 1).sum())\n",
        "            mlp_benign = int((dlq_pred == 0).sum())\n",
        "\n",
        "        # ==============================\n",
        "        # STAGE 4: MERGE & VERDICT\n",
        "        # ==============================\n",
        "        final_pred = np.zeros(len(df))\n",
        "        if len(main_pred) > 0: final_pred[main_df.index] = main_pred\n",
        "        if len(dlq_pred) > 0: final_pred[dlq_df.index] = dlq_pred\n",
        "\n",
        "        df[\"Verdict\"] = np.where(final_pred == 1, \"MALICIOUS\", \"BENIGN\")\n",
        "        malicious_count = int((final_pred == 1).sum())\n",
        "        benign_count = int((final_pred == 0).sum())\n",
        "        severity = (malicious_count / len(df)) * 100\n",
        "        gauge = create_gauge(severity)\n",
        "\n",
        "        # ==============================\n",
        "        # STAGE 5: DETECTED PERFORMANCE (REPORT)\n",
        "        # ==============================\n",
        "        report = f\"\"\"FORENSIC STREAM REPORT — NETWORK LOGS\n",
        "============================\n",
        "\n",
        "TOTAL LOGS\n",
        "----------------------------\n",
        "Total logs processed : {len(df)}\n",
        "\n",
        "GATEKEEPER STAGE (RandomForest)\n",
        "----------------------------\n",
        "Normal logs (Main)   : {gate_normal_count}\n",
