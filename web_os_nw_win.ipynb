        "            f\"| {ctx['total_pkts']:.0f} pkts | {ctx['total_bytes']:.0f} bytes \"\n",
        "            f\"| {ctx['duration_ms']:.0f}ms | retrans_in={ctx['retrans_in']:.3f}\"\n",
