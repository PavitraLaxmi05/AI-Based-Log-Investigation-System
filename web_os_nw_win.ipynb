        "        return gr.update(visible=True, value=path)\n",
        "\n",
        "    bulk_csv_btn.click(bulk_export, inputs=[analysis_state, report_box, gr.State(\"CSV\")], outputs=bulk_download)\n",
        "    bulk_json_btn.click(bulk_export, inputs=[analysis_state, report_box, gr.State(\"JSON\")], outputs=bulk_download)\n",
        "    bulk_pdf_btn.click(bulk_export, inputs=[analysis_state, report_box, gr.State(\"PDF\")], outputs=bulk_download)\n",
        "\n",
        "demo.launch()\n"
