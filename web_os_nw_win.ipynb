        "        inputs=[analysis_state, selected_log_type],\n",
        "        outputs=[dashboard_page, investigation_page, inspector_page, reports_page,\n",
        "                 raw_log_display, inspector_text, selected_row_state]\n",
        "    )\n",
        "\n",
        "    log_stream.select(\n",
        "        on_row_select,\n",
        "        inputs=[analysis_state, selected_log_type],\n",
        "        outputs=[dashboard_page, investigation_page, inspector_page, reports_page,\n",
        "                 raw_log_display, inspector_text, selected_row_state]\n",
        "    )\n",
        "\n",
        "    alerts_table.select(\n",
        "        on_row_select,\n",
        "        inputs=[analysis_state, selected_log_type],\n",
        "        outputs=[dashboard_page, investigation_page, inspector_page, reports_page,\n",
        "                 raw_log_display, inspector_text, selected_row_state]\n",
        "    )\n",
        "\n",
        "    log_stream.select(\n",
        "        on_row_select,\n",
        "        inputs=[analysis_state, selected_log_type],\n",
