      "cell_type": "code",
      "source": [
        "def decode_log_context(row_dict):\n",
        "    \"\"\"Convert raw numeric fields into human-readable strings for the LLM.\"\"\"\n",
        "    proto_num = int(row_dict.get(\"PROTOCOL\", 0))\n",
        "    l7_num = int(row_dict.get(\"L7_PROTO\", 0))\n",
        "    proto_name = PROTOCOL_MAP.get(proto_num, f\"Protocol {proto_num} (unknown)\")\n",
        "    l7_name = L7_PROTO_MAP.get(l7_num, f\"L7 Protocol {l7_num} (unrecognised — suspicious)\")\n",
        "\n",
        "    duration_ms = float(row_dict.get(\"FLOW_DURATION_MILLISECONDS\", 0))\n",
        "    total_bytes = float(row_dict.get(\"TOTAL_BYTES\",\n",
        "                        float(row_dict.get(\"IN_BYTES\", 0)) + float(row_dict.get(\"OUT_BYTES\", 0))))\n",
        "    total_pkts = float(row_dict.get(\"TOTAL_PKTS\", 0))\n",
        "    retrans_in = float(row_dict.get(\"RETRANS_RATIO_IN\", 0))\n",
        "    retrans_out = float(row_dict.get(\"RETRANS_RATIO_OUT\", 0))\n",
        "    byte_ratio = float(row_dict.get(\"BYTE_RATIO\", 0))\n",
        "    pkt_per_ms = float(row_dict.get(\"PKTS_PER_MS\", 0))\n",
        "    ttl_diff = float(row_dict.get(\"TTL_DIFF\", 0))\n",
        "    short_pkt = float(row_dict.get(\"SHORTEST_FLOW_PKT\", 0))\n",
        "    long_pkt = float(row_dict.get(\"LONGEST_FLOW_PKT\", 0))\n",
        "    raw_byte_ratio = float(row_dict.get(\"BYTE_RATIO\", 0))\n",
        "\n",
        "    # BYTE_RATIO is clipped at 500 during preprocessing — treat 500 as \"infinity\"\n",
        "    # (meaning zero or near-zero outbound traffic, not a real ratio of 500)\n",
        "    if raw_byte_ratio >= 499:\n",
        "        byte_ratio_display = \"≥500 (clipped — near-zero outbound traffic detected)\"\n",
        "        byte_ratio_flag = True\n",
        "    else:\n",
        "        byte_ratio_display = f\"{raw_byte_ratio:.2f}\"\n",
        "        byte_ratio_flag = False\n",
        "\n",
        "    return {\n",
        "        \"src_ip\": row_dict.get(\"IPV4_SRC_ADDR\", \"N/A\"),\n",
        "        \"dst_ip\": row_dict.get(\"IPV4_DST_ADDR\", \"N/A\"),\n",
        "        \"dst_port\": row_dict.get(\"L4_DST_PORT\", \"N/A\"),\n",
        "        \"transport\": proto_name,\n",
        "        \"app_protocol\": l7_name,\n",
        "        \"duration_ms\": duration_ms,\n",
        "        \"total_bytes\": total_bytes,\n",
        "        \"total_pkts\": total_pkts,\n",
        "        \"retrans_in\": retrans_in,\n",
        "        \"retrans_out\": retrans_out,\n",
        "        \"byte_ratio\": raw_byte_ratio,\n",
        "        \"byte_ratio_display\": byte_ratio_display,\n",
        "        \"byte_ratio_flag\": byte_ratio_flag,\n",
        "        \"pkt_per_ms\": pkt_per_ms,\n",
        "        \"ttl_diff\": ttl_diff,\n",
        "        \"short_pkt\": short_pkt,\n",
        "        \"long_pkt\": long_pkt,\n",
        "    }\n",
        "\n",
        "\n",
        "def get_llm_forensic_narrative(row_dict, contributions, prob, log_type=\"Network Log\"):\n",
        "    ctx = decode_log_context(row_dict)\n",
        "\n",
        "    # Build SHAP block\n",
        "    shap_lines = []\n",
        "    for feat, impact in contributions[:5]:\n",
        "        direction = \"RAISED\" if impact > 0 else \"LOWERED\"\n",
        "        raw_val = row_dict.get(feat, \"N/A\")\n",
        "        desc = FEATURE_DESCRIPTIONS.get(feat, feat)\n",
        "        shap_lines.append(\n",
        "            f\"  [{direction} score by {abs(impact):.4f}]  {feat} = {raw_val}  |  {desc}\"\n",
        "        )\n",
        "    shap_block = \"\\n\".join(shap_lines)\n",
        "\n",
        "    # behavioral profile\n",
        "    in_bytes = float(row_dict.get(\"IN_BYTES\", 0))\n",
        "    out_bytes = float(row_dict.get(\"OUT_BYTES\", 0))\n",
        "    in_pkts = float(row_dict.get(\"IN_PKTS\", 0))\n",
        "    out_pkts = float(row_dict.get(\"OUT_PKTS\", 0))\n",
        "    retrans_in = float(row_dict.get(\"RETRANS_RATIO_IN\", 0))\n",
        "    retrans_out = float(row_dict.get(\"RETRANS_RATIO_OUT\", 0))\n",
        "    pkt_per_ms = float(row_dict.get(\"PKTS_PER_MS\", 0))\n",
        "    ttl_diff = float(row_dict.get(\"TTL_DIFF\", 0))\n",
        "    tcp_flags = int(row_dict.get(\"TCP_FLAGS\", 0))\n",
        "    short_pkt = float(row_dict.get(\"SHORTEST_FLOW_PKT\", 0))\n",
        "    long_pkt = float(row_dict.get(\"LONGEST_FLOW_PKT\", 0))\n",
        "    duration_ms = float(row_dict.get(\"FLOW_DURATION_MILLISECONDS\", 0))\n",
        "\n",
        "    # Derived interpretations\n",
        "    flow_direction = \"inbound-heavy\" if in_bytes > out_bytes * 2 else \\\n",
        "                     \"outbound-heavy\" if out_bytes > in_bytes * 2 else \"balanced\"\n",
        "\n",
        "    retrans_assessment = \"normal\"\n",
        "    if retrans_in > 0.5 or retrans_out > 0.5:\n",
        "        retrans_assessment = \"HIGH — possible brute force or unstable malicious connection\"\n",
        "    elif retrans_in > 0.2 or retrans_out > 0.2:\n",
        "        retrans_assessment = \"ELEVATED — worth investigating\"\n",
        "\n",
        "    pkt_rate_assessment = \"normal\"\n",
        "    if pkt_per_ms > 10:\n",
        "        pkt_rate_assessment = \"VERY HIGH — possible flooding or DDoS\"\n",
        "    elif pkt_per_ms > 3:\n",
        "        pkt_rate_assessment = \"ELEVATED — possible scanning\"\n",
        "\n",
        "    ttl_assessment = \"normal\"\n",
        "    if ttl_diff > 100:\n",
        "        ttl_assessment = \"HIGH — traffic may be spoofed or traversing unexpected hops\"\n",
        "    elif ttl_diff > 50:\n",
        "        ttl_assessment = \"ELEVATED\"\n",
        "\n",
        "    # Byte ratio interpretation\n",
        "    if ctx[\"byte_ratio_flag\"]:\n",
        "        byte_ratio_note = (\n",
        "            f\"CLIPPED AT 500 — actual ratio is much higher, meaning outbound traffic \"\n",
        "            f\"is near-zero ({out_bytes:.0f} bytes out vs {in_bytes:.0f} bytes in). \"\n",
        "            f\"This is consistent with a server pushing data to a passive listener, \"\n",
        "            f\"or a one-way covert channel.\"\n",
        "        )\n",
        "    else:\n",
        "        ratio = ctx[\"byte_ratio\"]\n",
        "        if ratio > 50:\n",
        "            byte_ratio_note = f\"{ratio:.1f} — strongly inbound-heavy (possible download or data push)\"\n",
        "        elif ratio < 0.02:\n",
        "            byte_ratio_note = f\"{ratio:.4f} — strongly outbound-heavy (possible exfiltration or upload)\"\n",
        "        else:\n",
        "            byte_ratio_note = f\"{ratio:.2f} — roughly balanced\"\n",
        "\n",
        "    # TCP flag interpretation\n",
        "    flag_notes = []\n",
        "    if tcp_flags & 0x02: flag_notes.append(\"SYN\")\n",
        "    if tcp_flags & 0x10: flag_notes.append(\"ACK\")\n",
        "    if tcp_flags & 0x01: flag_notes.append(\"FIN\")\n",
        "    if tcp_flags & 0x04: flag_notes.append(\"RST\")\n",
        "    if tcp_flags & 0x08: flag_notes.append(\"PSH\")\n",
        "    tcp_flag_str = \"+\".join(flag_notes) if flag_notes else f\"raw={tcp_flags}\"\n",
        "\n",
        "    if prob < 0.40:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT — CRITICAL:\n",
        "  The ML confidence is only {prob:.1%}. This means the model is NOT confident this is malicious.\n",
        "  - Do NOT classify this as a confirmed attack.\n",
        "  - Do NOT recommend blocking production traffic based on this alone.\n",
        "  - Your VERDICT must explicitly state this is a low-confidence flag.\n",
        "  - Your ATTACK VECTOR must say \"insufficient evidence to classify\" if SHAP values are all near zero.\n",
        "  - Your REMEDIATION should focus on observation and correlation, NOT blocking.\n",
        "  - If all SHAP values are < 0.001, state clearly: \"SHAP provides no explanation —\n",
        "    this flag may be a false positive driven by a feature combination not represented\n",
        "    in the top contributors.\"\n",
        "\"\"\"\n",
        "    elif prob < 0.65:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT:\n",
        "  The ML confidence is {prob:.1%} — moderate suspicion only.\n",
        "  - Treat this as a lead for investigation, not a confirmed incident.\n",
        "  - Your VERDICT should reflect uncertainty appropriately.\n",
        "  - Remediation should be investigative, not immediately blocking.\n",
        "\"\"\"\n",
        "    else:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT:\n",
        "  The ML confidence is {prob:.1%} — high confidence malicious.\n",
        "  - This warrants immediate investigation and likely containment.\n",
        "  - Be specific and decisive in your recommendations.\n",
        "\"\"\"\n",
        "\n",
        "    prompt = f\"\"\"You are a senior SOC analyst. Analyse this flagged network flow and write a forensic report entry. {confidence_instruction}\n",
        "\n",
        "FLOW IDENTITY:\n",
        "  Source IP         : {ctx['src_ip']}\n",
        "  Destination IP    : {ctx['dst_ip']}  Port: {ctx['dst_port']}\n",
        "  Transport         : {ctx['transport']}\n",
        "  App Protocol      : {ctx['app_protocol']}\n",
        "  ML Confidence     : {prob:.1%} MALICIOUS\n",
        "\n",
        "FULL BEHAVIORAL PROFILE:\n",
        "  Duration              : {duration_ms:.0f} ms\n",
        "  Inbound bytes         : {in_bytes:.0f}  |  Outbound bytes: {out_bytes:.0f}\n",
        "  Inbound packets       : {in_pkts:.0f}   |  Outbound packets: {out_pkts:.0f}\n",
        "  Bytes per pkt (in)    : {(in_bytes/in_pkts if in_pkts > 0 else 0):.1f}  |  Bytes per pkt (out): {(out_bytes/out_pkts if out_pkts > 0 else 0):.1f}\n",
        "  Packet size range     : {short_pkt:.0f} – {long_pkt:.0f} bytes\n",
        "  Packet rate           : {pkt_per_ms:.4f} pkts/ms  [{pkt_rate_assessment}]\n",
        "  Flow direction bias   : {flow_direction}\n",
        "  Byte ratio (in/out)   : {byte_ratio_note}\n",
        "  Retransmit ratio IN   : {retrans_in:.3f}  [{retrans_assessment}]\n",
        "  Retransmit ratio OUT  : {retrans_out:.3f}\n",
        "  TTL variance          : {ttl_diff:.0f}  [{ttl_assessment}]\n",
        "  TCP flags             : {tcp_flag_str}\n",
        "\n",
        "TOP SHAP CONTRIBUTORS (note: small values mean no single feature dominated —\n",
        "the model flagged this due to a combination of subtle anomalies):\n",
        "{shap_block}\n",
        "\n",
        "\n",
        "INTERPRETATION GUIDE (use these to reason, do not copy verbatim):\n",
        "  - Packet size 40 bytes = TCP ACK. A flow of 500+ ACK packets with no data suggests\n",
        "    a long-lived keepalive, an empty polling loop, or an encrypted C2 channel heartbeat.\n",
        "  - Byte ratio clipped at 500 + near-zero out_bytes = the destination sent data but\n",
        "    the source sent almost nothing back. Consistent with: a compromised host receiving\n",
        "    commands silently, a data push from a C2 server, or a reverse shell output stream.\n",
        "  - Unknown L7 protocol on a high packet count over TCP = likely encrypted or custom\n",
        "    protocol, not a standard application. Could be encrypted C2, custom malware comms,\n",
        "    or tunnelled traffic.\n",
        "  - All SHAP values < 0.01 = no single feature is highly anomalous; the model recognised\n",
        "    the overall traffic *pattern* as matching known attack signatures in training data.\n",
        "  - If source and destination are both internal (192.168.x.x), consider lateral movement.\n",
        "  - If destination is external (public IP), consider exfiltration or C2 callback.\n",
        "\n",
        "Respond in EXACTLY this format:\n",
        "\n",
        "VERDICT:\n",
        "[2 sentences. What does this flow most likely represent? Cite specific values.]\n",
        "\n",
        "ATTACK VECTOR:\n",
        "[1 sentence. Name the most likely attack class and the 2-3 values that support it.\n",
        "If genuinely uncertain between two options, name both and explain why.]\n",
        "\n",
        "REMEDIATION:\n",
        "1. [Firewall/ACL action with specific src/dst IP and port]\n",
        "2. [Detection rule using a specific threshold from the behavioral profile above]\n",
        "3. [Escalation or forensic investigation step]\"\"\"\n",
        "\n",
        "    try:\n",
        "        response = groq_client.chat.completions.create(\n",
        "            model=\"llama-3.3-70b-versatile\",\n",
        "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "            temperature=0.1,\n",
        "            max_tokens=500\n",
        "        )\n",
        "        return response.choices[0].message.content.strip()\n",
        "    except Exception as e:\n",
        "        return f\"[LLM unavailable: {e}]\"\n",
        "\n",
        "\n",
        "def get_llm_batch_pattern_summary(all_logs_context):\n",
        "    \"\"\"\n",
        "    Called ONCE per batch after all individual logs are analysed.\n",
        "    Detects cross-log patterns (same src IP hitting multiple destinations = scanning,\n",
