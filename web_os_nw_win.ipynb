        "                 raw_log_display, inspector_text, selected_row_state]\n",
        "    )\n",
        "\n",
        "    # ── SINGLE LOG EXPORTS ───────────────────────────────────\n",
        "    exp_csv_btn.click(\n",
        "        lambda row_json, shap_txt: gr.update(visible=True, value=export_single_log_report(row_json, shap_txt, \"CSV\")),\n",
        "        inputs=[selected_row_state, inspector_text],\n",
        "        outputs=inspector_download\n",
        "    )\n",
        "    exp_json_btn.click(\n",
        "        lambda row_json, shap_txt: gr.update(visible=True, value=export_single_log_report(row_json, shap_txt, \"JSON\")),\n",
        "        inputs=[selected_row_state, inspector_text],\n",
        "        outputs=inspector_download\n",
        "    )\n",
        "    exp_pdf_btn.click(\n",
        "        lambda row_json, shap_txt: gr.update(visible=True, value=export_single_log_report(row_json, shap_txt, \"PDF\")),\n",
        "        inputs=[selected_row_state, inspector_text],\n",
        "        outputs=inspector_download\n",
        "    )\n",
        "\n",
        "    # ── BULK EXPORTS (Forensic Reports page) ─────────────────\n",
        "    def bulk_export(full_df, report_text, fmt):\n",
        "        if full_df is None or full_df.empty:\n",
        "            return gr.update(visible=False)\n",
