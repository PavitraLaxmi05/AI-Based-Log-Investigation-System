        "\n",
        "L7_PROTO_MAP = {\n",
        "    0: \"Unknown\", 7: \"Echo\", 21: \"FTP\", 22: \"SSH\", 23: \"Telnet\",\n",
        "    25: \"SMTP\", 53: \"DNS\", 67: \"DHCP\", 80: \"HTTP\", 91: \"MIT-ML-DEV (unusual)\",\n",
        "    110: \"POP3\", 143: \"IMAP\", 443: \"HTTPS/TLS\", 465: \"SMTPS\",\n",
        "    993: \"IMAPS\", 3306: \"MySQL\", 5432: \"PostgreSQL\", 6379: \"Redis\",\n",
        "    8080: \"HTTP-Alt\", 8443: \"HTTPS-Alt\", 265: \"Unknown/Rare Protocol (suspicious)\"}\n",
        "\n",
        "FEATURE_DESCRIPTIONS = {\n",
        "    \"SHORTEST_FLOW_PKT\":           \"minimum packet size in bytes (small = possible ACK-only or stealth traffic)\",\n",
        "    \"LONGEST_FLOW_PKT\":            \"maximum packet size in bytes\",\n",
        "    \"IN_BYTES\":                    \"total inbound bytes\",\n",
        "    \"OUT_BYTES\":                   \"total outbound bytes\",\n",
        "    \"IN_PKTS\":                     \"total inbound packet count\",\n",
        "    \"OUT_PKTS\":                    \"total outbound packet count\",\n",
        "    \"TOTAL_BYTES\":                 \"total bytes both directions\",\n",
        "    \"TOTAL_PKTS\":                  \"total packets both directions\",\n",
        "    \"FLOW_DURATION_MILLISECONDS\":  \"flow duration in milliseconds\",\n",
        "    \"BYTE_RATIO\":                  \"inbound/outbound byte ratio (high = more data received than sent)\",\n",
        "    \"PKT_RATIO\":                   \"inbound/outbound packet ratio\",\n",
        "    \"BYTES_PER_PKT_IN\":            \"average inbound payload size per packet\",\n",
        "    \"BYTES_PER_PKT_OUT\":           \"average outbound payload size per packet\",\n",
        "    \"BYTES_PER_MS\":                \"data throughput in bytes per millisecond\",\n",
        "    \"PKTS_PER_MS\":                 \"packet rate per millisecond (high = flooding/DDoS)\",\n",
        "    \"PKT_SIZE_RATIO\":              \"ratio of largest to smallest packet (high = fragmentation or evasion)\",\n",
        "    \"RETRANS_RATIO_IN\":            \"fraction of inbound packets retransmitted (high = connection instability or brute force)\",\n",
        "    \"RETRANS_RATIO_OUT\":           \"fraction of outbound packets retransmitted\",\n",
        "    \"RETRANSMITTED_IN_PKTS\":       \"count of retransmitted inbound packets\",\n",
        "    \"RETRANSMITTED_OUT_PKTS\":      \"count of retransmitted outbound packets\",\n",
        "    \"TTL_DIFF\":                    \"difference between max and min TTL (high = traffic through unexpected hops or spoofing)\",\n",
        "    \"MIN_TTL\":                     \"minimum Time-To-Live value observed\",\n",
        "    \"MAX_TTL\":                     \"maximum Time-To-Live value observed\",\n",
        "    \"TCP_FLAGS\":                   \"combined TCP flags bitmask\",\n",
        "    \"CLIENT_TCP_FLAGS\":            \"TCP flags set by client side\",\n",
        "    \"SERVER_TCP_FLAGS\":            \"TCP flags set by server side\",\n",
        "    \"L7_PROTO\":                    \"application layer protocol ID\",\n",
        "    \"PROTOCOL\":                    \"transport layer protocol number\"\n",
        "}\n",
