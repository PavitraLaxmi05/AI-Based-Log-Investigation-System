    {
      "cell_type": "code",
      "source": [
        "# ==============================\n",
        "# OS LOG — DECODER + LLM\n",
        "# ==============================\n",
        "\n",
        "SYSCALL_MAP = {\n",
        "    59: \"execve (process execution — high risk)\",\n",
        "    101: \"ptrace (process injection — high risk)\",\n",
        "    56: \"clone (process cloning)\",\n",
        "    105: \"sethostname (hostname change)\",\n",
        "    117: \"setresuid (UID manipulation — privilege escalation)\",\n",
        "    2: \"open (file access)\",\n",
        "    3: \"close (file close)\",\n",
        "    11: \"execve (legacy)\",\n",
        "    39: \"getpid\",\n",
        "    62: \"kill (signal sent to process)\",\n",
        "    87: \"unlink (file deletion)\",\n",
        "    257: \"openat (file access)\",\n",
        "    263: \"unlinkat (file deletion)\"\n",
        "}\n",
        "\n",
        "RULE_LEVEL_MAP = {\n",
        "    0: \"informational\",\n",
        "    1: \"informational\", 2: \"informational\", 3: \"informational\",\n",
        "    4: \"low\", 5: \"low\", 6: \"low\",\n",
        "    7: \"medium\", 8: \"medium\", 9: \"medium\",\n",
        "    10: \"high — security event\", 11: \"high — security event\", 12: \"high — security event\",\n",
        "    13: \"critical — attack likely\", 14: \"critical — attack likely\", 15: \"critical — attack likely\"\n",
        "}\n",
        "\n",
        "OS_FEATURE_DESCRIPTIONS = {\n",
        "    \"effective_uid\": \"effective user ID (0 = root/superuser — privilege escalation risk)\",\n",
        "    \"_source.rule.level\": \"Wazuh/OSSEC rule severity level (10+ = high, 13+ = critical)\",\n",
        "    \"_source.rule.firedtimes\": \"number of times this rule has triggered (high = persistent activity)\",\n",
        "    \"_source.data.audit.syscall\": \"Linux syscall number invoked by the process\",\n",
        "    \"_source.data.audit.success\": \"whether the syscall succeeded (failure = possible blocked attack)\",\n",
        "    \"_source.syscheck.event\": \"file integrity monitoring event (modification/creation/deletion)\",\n",
        "    \"hour_sin\": \"sine encoding of event hour (temporal anomaly detection)\",\n",
        "    \"hour_cos\": \"cosine encoding of event hour (temporal anomaly detection)\",\n",
        "}\n",
        "\n",
        "\n",
        "def decode_os_log_context(row_dict, raw_row_dict=None):\n",
        "    \"\"\"\n",
        "    Converts raw OS log fields into human-readable context for the LLM.\n",
        "    raw_row_dict: the original unencoded row (before LabelEncoder) for string fields.\n",
        "    \"\"\"\n",
        "    src = raw_row_dict if raw_row_dict else row_dict\n",
        "\n",
        "    uid = float(row_dict.get(\"effective_uid\", -1))\n",
        "    uid_str = \"root (UID=0) — full superuser access\" if uid == 0 else \\\n",
        "              f\"UID={uid:.0f} — standard user\" if uid > 0 else \"unknown\"\n",
        "\n",
        "    syscall_raw = str(row_dict.get(\"_source.data.audit.syscall\", \"\"))\n",
        "    syscall_num = int(float(syscall_raw)) if syscall_raw.replace('.','').lstrip('-').isdigit() else -1\n",
        "    syscall_str = SYSCALL_MAP.get(syscall_num, f\"syscall {syscall_num} (unmapped)\")\n",
        "\n",
        "    rule_raw = str(row_dict.get(\"_source.rule.level\", \"0\"))\n",
        "    rule_level = int(float(rule_raw)) if rule_raw.replace('.','').isdigit() else 0\n",
        "    rule_level_str = RULE_LEVEL_MAP.get(min(rule_level, 15), \"unknown severity\")\n",
        "\n",
        "    fired_times = float(row_dict.get(\"_source.rule.firedtimes\", 0))\n",
        "\n",
        "    audit_success = str(src.get(\"_source.data.audit.success\", \"unknown\")).lower()\n",
        "    audit_success_str = \"FAILED (access denied or blocked)\" if audit_success in [\"no\", \"0\", \"false\"] \\\n",
        "                        else \"succeeded\" if audit_success in [\"yes\", \"1\", \"true\"] \\\n",
        "                        else \"unknown\"\n",
        "\n",
        "    agent_name = str(src.get(\"_source.agent.name\", row_dict.get(\"_source.agent.name\", \"N/A\")))\n",
        "    agent_ip = str(src.get(\"_source.agent.ip\", row_dict.get(\"_source.agent.ip\", \"N/A\")))\n",
        "    exe = str(src.get(\"_source.data.audit.exe\", row_dict.get(\"_source.data.audit.exe\", \"N/A\")))\n",
        "    command = str(src.get(\"executed_command\", row_dict.get(\"executed_command\", \"N/A\")))\n",
        "    syscheck = str(src.get(\"_source.syscheck.event\", row_dict.get(\"_source.syscheck.event\", \"N/A\")))\n",
        "\n",
        "    return {\n",
        "        \"agent_name\": agent_name,\n",
        "        \"agent_ip\": agent_ip,\n",
        "        \"executable\": exe,\n",
        "        \"command\": command,\n",
        "        \"uid_str\": uid_str,\n",
        "        \"uid_raw\": uid,\n",
        "        \"syscall_str\": syscall_str,\n",
        "        \"syscall_num\": syscall_num,\n",
        "        \"rule_level\": rule_level,\n",
        "        \"rule_level_str\": rule_level_str,\n",
        "        \"fired_times\": fired_times,\n",
        "        \"audit_success_str\": audit_success_str,\n",
        "        \"syscheck_event\": syscheck,\n",
        "    }\n",
        "\n",
        "\n",
        "def get_llm_os_narrative(row_dict, contributions, prob, raw_row_dict=None):\n",
        "    \"\"\"\n",
        "    LLM forensic narrative for a single OS log.\n",
        "    Called max 5 times per batch.\n",
        "    \"\"\"\n",
        "    ctx = decode_os_log_context(row_dict, raw_row_dict)\n",
        "\n",
        "    shap_lines = []\n",
        "    for feat, impact in contributions[:5]:\n",
        "        direction = \"RAISED\" if impact > 0 else \"LOWERED\"\n",
        "        raw_val = row_dict.get(feat, \"N/A\")\n",
        "        desc = OS_FEATURE_DESCRIPTIONS.get(feat, feat)\n",
        "        shap_lines.append(\n",
        "            f\"  [{direction} threat by {abs(impact):.4f}]  {feat} = {raw_val}  |  {desc}\"\n",
        "        )\n",
        "    shap_block = \"\\n\".join(shap_lines)\n",
        "\n",
        "    if prob < 0.40:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT — CRITICAL:\n",
        "  ML confidence is only {prob:.1%}. Do NOT classify as confirmed attack.\n",
        "  State this is a low-confidence flag. Focus remediation on observation only.\n",
        "  If SHAP values are all < 0.01, state SHAP provides no clear explanation.\"\"\"\n",
        "    elif prob < 0.65:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT:\n",
        "  ML confidence is {prob:.1%} — moderate suspicion.\n",
        "  Treat as investigation lead, not confirmed incident.\"\"\"\n",
        "    else:\n",
        "        confidence_instruction = f\"\"\"\n",
        "CONFIDENCE CONTEXT:\n",
        "  ML confidence is {prob:.1%} — high confidence malicious.\n",
        "  Recommend immediate investigation and containment.\"\"\"\n",
        "\n",
        "    prompt = f\"\"\"You are a senior Linux security analyst writing a forensic incident report entry.\n",
        "{confidence_instruction}\n",
        "\n",
        "HOST CONTEXT:\n",
        "  Agent / Hostname  : {ctx['agent_name']}\n",
        "  Agent IP          : {ctx['agent_ip']}\n",
        "  Executable        : {ctx['executable']}\n",
        "  Command executed  : {ctx['command']}\n",
        "  Effective UID     : {ctx['uid_str']}\n",
        "  Syscall invoked   : {ctx['syscall_str']}\n",
        "  Rule severity     : Level {ctx['rule_level']} — {ctx['rule_level_str']}\n",
        "  Rule fired times  : {ctx['fired_times']:.0f}\n",
        "  Audit result      : {ctx['audit_success_str']}\n",
        "  File integrity    : {ctx['syscheck_event']}\n",
        "  ML Confidence     : {prob:.1%} MALICIOUS\n",
        "\n",
        "TOP SHAP CONTRIBUTORS:\n",
        "{shap_block}\n",
        "\n",
        "INTERPRETATION GUIDE (reason from these, do not copy verbatim):\n",
        "  - UID=0 + execve syscall = process ran as root and spawned a child process.\n",
        "    Most dangerous combination — possible rootkit, backdoor, or privilege abuse.\n",
        "  - ptrace (101) = process injection. Attacker may be reading/writing another process memory.\n",
        "  - Rule level 13+ = Wazuh considers this a confirmed attack signature, not just anomaly.\n",
        "  - Rule fired many times (>10) = persistent repeated behaviour, not a one-off event.\n",
        "  - Audit success=FAILED = the OS blocked the action. Still worth investigating — attacker probing.\n",
        "  - File integrity event = a file was modified, created, or deleted outside normal change windows.\n",
        "  - If executable is /bin/bash, /bin/sh, or similar shell + root UID = likely interactive root shell.\n",
        "  - If command contains wget, curl, nc, ncat, python -c, base64 = likely download or reverse shell.\n",
        "  - Internal agent IP = this is endpoint activity, not network traffic. Focus on process and file forensics.\n",
        "\n",
        "Respond in EXACTLY this format:\n",
        "\n",
        "VERDICT:\n",
        "[2 sentences. What does this OS event most likely represent? Cite the executable, UID, and syscall specifically.]\n",
        "\n",
        "ATTACK VECTOR:\n",
        "[1 sentence. Name the attack class (e.g. privilege escalation, reverse shell, lateral movement, persistence mechanism, credential theft) and cite the 2-3 specific values that support it.]\n",
        "\n",
        "REMEDIATION:\n",
        "1. [Endpoint action: kill process, isolate host, or revoke credentials — be specific to the host/user above]\n",
        "2. [Detection rule: specific threshold using rule level, fired times, UID, or syscall number]\n",
        "3. [Forensic investigation step: what to examine next on this host]\"\"\"\n",
        "\n",
        "    try:\n",
        "        response = groq_client.chat.completions.create(\n",
        "            model=\"llama-3.3-70b-versatile\",\n",
        "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "            temperature=0.1,\n",
        "            max_tokens=500\n",
