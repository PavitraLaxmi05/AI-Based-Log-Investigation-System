        "\n",
        "Respond in EXACTLY this format:\n",
        "\n",
        "VERDICT:\n",
        "[2 sentences max. Use the Event ID to explain the specific Windows security implication (e.g., privilege escalation, account lockout, or lateral movement).]\n",
        "\n",
        "ATTACK VECTOR:\n",
        "[1 sentence naming the MITRE ATT&CK category and supporting feature values.]\n",
        "\n",
        "REMEDIATION:\n",
        "1. [Specific host-based action: e.g., Disable account, isolate workstation, or rotate credentials]\n",
        "2. [Specific GPO or SIEM rule threshold recommendation]\n",
        "3. [Forensic next step: e.g., Check Event ID 4688 for process creation or 4672 for special privileges]\"\"\"\n",
        "\n",
        "    try:\n",
        "        response = groq_client.chat.completions.create(\n",
        "            model=\"llama-3.3-70b-versatile\",\n",
        "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "            temperature=0.1,\n",
        "            max_tokens=400\n",
        "        )\n",
        "        return response.choices[0].message.content.strip()\n",
        "    except Exception as e:\n",
        "        return f\"Narrative failed: {e}\"\n",
        "def get_llm_windows_batch_summary(all_windows_context):\n",
        "    \"\"\"\n",
        "    Analyzes multiple flagged Windows logs to detect batch-wide patterns\n",
        "    (e.g., one IP hitting multiple accounts, or one host dumping credentials).\n",
        "    \"\"\"\n",
        "    if not all_windows_context:\n",
        "        return \"\"\n",
        "\n",
        "    lines = []\n",
        "    for i, ctx in enumerate(all_windows_context, 1):\n",
        "        lines.append(\n",
        "            f\"  Log {i}: EventID {ctx.get('event_id')} | Source: {ctx.get('source')} \"\n",
        "            f\"| Category: {ctx.get('task_category')} | Message: {str(ctx.get('message'))[:80]}...\"\n",
        "        )\n",
        "    logs_block = \"\\n\".join(lines)\n",
        "\n",
        "    prompt = f\"\"\"You are a senior Windows Incident Responder. Review these {len(all_windows_context)} flagged Windows security events from a single analysis batch.\n",
        "\n",
        "FLAGGED WINDOWS EVENTS:\n",
        "{logs_block}\n",
        "\n",
        "Identify cross-event patterns in 3-5 sentences:\n",
        "- Is there a specific Event ID dominating the batch? (e.g., 4625 for brute force, 4672 for admin login)\n",
        "- Are the events coming from a single source or multiple hosts?\n",
        "- Does the sequence suggest an attack stage (Enumeration, Exploitation, Lateral Movement, or Persistence)?\n",
        "- Are the timestamps suggests automated/scripted behavior?\n",
        "\n",
        "Then give ONE overall campaign classification and ONE host-wide remediation recommendation.\n",
        "\n",
        "Format:\n",
        "PATTERN ANALYSIS:\n",
        "[3-5 sentences describing the observed trend across all events]\n",
        "\n",
        "CAMPAIGN TYPE:\n",
        "[Single classification: e.g. \"Automated Brute Force Attack\" or \"Post-Exploitation Credential Dumping\"]\n",
        "\n",
        "SYSTEM-WIDE ACTION:\n",
        "[One specific GPO update, account lockout policy, or host isolation command]\"\"\"\n",
        "\n",
        "    try:\n",
        "        response = groq_client.chat.completions.create(\n",
        "            model=\"llama-3.3-70b-versatile\",\n",
        "            messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "            temperature=0.1,\n",
        "            max_tokens=400\n",
        "        )\n",
        "        return response.choices[0].message.content.strip()\n",
        "    except Exception as e:\n",
        "        return f\"[Windows Batch Summary unavailable: {e}]\"\n",
        "\n",
        "def get_llm_windows_narrative1(row):\n",
        "    message = row.get(\"message\", \"\")\n",
        "    if not isinstance(message, str):\n",
        "        message = str(message) if message is not None else \"No message available\"\n",
        "    message = message[:300]\n",
        "    verdict = row.get(\"verdict\", \"MALICIOUS\")\n",
        "    prompt = f\"\"\"\n",
        "You are a SOC analyst analyzing a Windows log.\n",
        "\n",
        "LOG DETAILS:\n",
        "Event ID: {row.get('event_id')}\n",
        "Source: {row.get('source')}\n",
        "Message: {message}\n",
        "\n",
        "MODEL VERDICT: {verdict}\n",
        "\n",
        "STRICT RULES:\n",
        "- If verdict is BENIGN -> explain why it is normal activity\n",
        "- If MALICIOUS -> explain attack\n",
        "- If SUSPICIOUS -> explain both possibilities\n",
        "\n",
        "Respond in this format:\n",
        "\n",
        "VERDICT:\n",
        "...\n",
        "\n",
        "REASON:\n",
        "...\n",
        "\n",
        "ACTION:\n",
        "...\n",
        "\"\"\"\n",
        "    res = groq_client.chat.completions.create(\n",
        "        model=\"llama-3.3-70b-versatile\",\n",
        "        messages=[{\"role\": \"user\", \"content\": prompt}],\n",
        "        temperature=0.2,\n",
        "        max_tokens=250\n",
        "    )\n",
        "    return res.choices[0].message.content.strip()\n",
        "\n",
        "def generate_windows_forensic_explanation(dlq_df, dlq_pred, full_df):\n",
        "    try:\n",
        "        malicious_idx = np.where(dlq_pred == 1)[0]\n",
        "        if len(malicious_idx) == 0:\n",
        "            return \"No malicious Windows events detected.\"\n",
        "\n",
        "        top_n = min(5, len(malicious_idx))\n",
        "        sorted_indices = np.argsort(dlq_df.iloc[malicious_idx]['risk_score'].values)[::-1]\n",
        "        top_local = malicious_idx[sorted_indices[:top_n]]\n",
        "        top_global = dlq_df.index[top_local]\n",
        "\n",
        "        explainer = shap.TreeExplainer(ai_model)\n",
        "        X_explain = dlq_df[ai_features].fillna(0).iloc[top_local]\n",
        "        shap_values = explainer.shap_values(X_explain)\n",
        "\n",
        "        if isinstance(shap_values, list):\n",
        "            sv_matrix = shap_values[1] if len(shap_values) > 1 else shap_values[0]\n",
        "        else:\n",
        "            sv_matrix = shap_values\n",
        "\n",
        "        text = \"=\" * 60 + \"\\n\"\n",
        "        text += \"  AI FORENSIC EXPLANATION — WINDOWS SECURITY EVENTS\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\\n\"\n",
        "\n",
        "        all_windows_context = [] # FOR BATCH SUMMARY\n",
        "\n",
        "        for rank, (local_idx_in_subset, global_i) in enumerate(zip(range(top_n), top_global)):\n",
        "            row_dict = full_df.loc[global_i].to_dict()\n",
        "\n",
        "            text += f\"LOG #{rank+1} — Event ID: {row_dict.get('event_id')} | {row_dict.get('task_category', 'System')}\\n\"\n",
        "            text += \"-\" * 50 + \"\\n\"\n",
        "            text += f\"  Source       : {row_dict.get('source', 'N/A')}\\n\"\n",
        "            text += f\"  Message      : {str(row_dict.get('message', ''))[:120]}...\\n\\n\"\n",
        "\n",
        "            # SHAP calculations\n",
        "            sv_row = sv_matrix[local_idx_in_subset]\n",
        "            contributions = []\n",
        "            for feat, val in zip(ai_features, sv_row):\n",
        "                impact = float(val[0]) if isinstance(val, (np.ndarray, list)) else float(val)\n",
        "                contributions.append((feat, impact))\n",
        "\n",
        "            contributions = sorted(contributions, key=lambda x: abs(x[1]), reverse=True)[:5]\n",
        "\n",
        "            text += \"  Top Contributing Features (SHAP):\\n\"\n",
        "            for feat, impact in contributions:\n",
        "                direction = \"↑ INCREASED\" if impact > 0 else \"↓ decreased\"\n",
        "                raw_val = X_explain.iloc[local_idx_in_subset][feat]\n",
        "                bar = \"█\" * int(min(abs(impact) * 20, 20))\n",
        "                desc = WINDOWS_FEATURE_DESCRIPTIONS.get(feat, feat)\n",
        "                text += f\"    • {feat:<18} = {float(raw_val):>10.2f} → {direction} (SHAP: {impact:+.4f}) {bar}\\n\"\n",
        "                text += f\"      ↳ {desc}\\n\"\n",
        "\n",
        "            text += \"\\n  AI FORENSIC NARRATIVE:\\n\"\n",
        "            text += \"  \" + \"-\" * 48 + \"\\n\"\n",
        "            llm_text = get_llm_windows_narrative(row_dict)\n",
        "            text += f\"  {llm_text}\\n\\n\"\n",
        "\n",
        "            # COLLECT CONTEXT FOR BATCH ANALYSIS\n",
        "            all_windows_context.append(row_dict)\n",
        "\n",
        "        # ============================================================\n",
        "        # NEW: ADD BATCH PATTERN ANALYSIS AT THE END (Like Network Logs)\n",
        "        # ============================================================\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        text += \"  CROSS-LOG PATTERN ANALYSIS (Threat Hunter View)\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "\n",
        "        batch_summary = get_llm_windows_batch_summary(all_windows_context)\n",
        "        text += f\"{batch_summary}\\n\\n\"\n",
        "\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "        text += f\"  BATCH SUMMARY: {len(malicious_idx)} malicious events detected.\\n\"\n",
        "        text += \"=\" * 60 + \"\\n\"\n",
        "\n",
        "        return text\n",
        "    except Exception as e:\n",
        "        import traceback\n",
        "        return f\"Windows Forensic Explanation Error:\\n{traceback.format_exc()}\"\n",
        "\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "FILE_PATH = \"/content/drive/MyDrive/Colab Notebooks/\"\n",
        "\n",
        "ai_package = joblib.load(FILE_PATH + \"windows_threat_model.pkl\")\n",
        "ai_model = ai_package[\"model\"]\n",
        "ai_features = ai_package[\"features\"]\n",
        "mlp_model = load_model(FILE_PATH + \"windows_mlp_model.h5\")\n",
        "mlp_scaler = joblib.load(FILE_PATH + \"windows_mlp_scaler.pkl\")\n",
        "\n",
        "def feature_engineering(df):\n",
        "    df.columns = df.columns.str.strip().str.replace(\" \", \"_\").str.lower()\n",
        "    df[\"event_id\"] = pd.to_numeric(df[\"event_id\"], errors=\"coerce\").fillna(0)\n",
        "    df[\"date_and_time\"] = pd.to_datetime(\n",
        "        df[\"date_and_time\"],\n",
        "        format=\"%d.%m.%Y. %H:%M:%S\",\n",
        "        errors=\"coerce\"\n",
        "    )\n",
        "    df = df.sort_values(\"date_and_time\")\n",
        "    df[\"hour\"] = df[\"date_and_time\"].dt.hour.fillna(0)\n",
        "    df[\"night_activity\"] = ((df[\"hour\"] < 5) | (df[\"hour\"] > 23)).astype(int)\n",
        "    df[\"event_freq\"] = df.groupby(\"event_id\").cumcount()\n",
        "    df[\"burst_count\"] = df[\"event_freq\"].clip(upper=10)\n",
        "    df[\"time_diff\"] = df[\"date_and_time\"].diff().dt.total_seconds().fillna(0)\n",
        "    return df\n",
        "\n",
        "def run_windows_pipeline(df):\n",
        "    df = feature_engineering(df)\n",
        "    X = df[ai_features]\n",
        "    if hasattr(ai_model, \"feature_names_in_\"):\n",
        "        X = X[ai_model.feature_names_in_]\n",
        "    probs = ai_model.predict_proba(X)[:, 1]\n",
        "    t1 = np.percentile(probs, 90)\n",
        "    t2 = np.percentile(probs, 98)\n",
        "    df[\"risk_score\"] = 0\n",
        "    df.loc[probs > t1, \"risk_score\"] = 1\n",
        "    df.loc[probs > t2, \"risk_score\"] = 2\n",
        "    dlq_mask = df[\"risk_score\"] >= 1\n",
        "    dlq_df = df[dlq_mask].copy()\n",
        "    if len(dlq_df) > 0:\n",
        "        dlq_df[\"hour\"] = dlq_df[\"date_and_time\"].dt.hour\n",
        "        dlq_df[\"is_night\"] = ((dlq_df[\"hour\"] < 6) | (dlq_df[\"hour\"] > 22)).astype(int)\n",
        "        features = [\"event_id\", \"event_freq\", \"burst_count\", \"hour\", \"is_night\"]\n",
        "        X_mlp = dlq_df[features]\n",
        "        if hasattr(mlp_scaler, \"feature_names_in_\"):\n",
        "            X_mlp = X_mlp.reindex(columns=mlp_scaler.feature_names_in_, fill_value=0)\n",
        "        X_mlp = mlp_scaler.transform(X_mlp)\n",
        "        probs_mlp = mlp_model.predict(X_mlp)\n",
        "        threshold = np.percentile(probs_mlp, 95)\n",
        "        dlq_df[\"mlp_flag\"] = (probs_mlp.flatten() > threshold).astype(int)\n",
        "        df.loc[dlq_df.index, \"mlp_flag\"] = dlq_df[\"mlp_flag\"]\n",
        "    else:\n",
        "        df[\"mlp_flag\"] = 0\n",
        "    df[\"mlp_flag\"] = df[\"mlp_flag\"].fillna(0)\n",
        "    df[\"Verdict\"] = np.where(\n",
        "        (df[\"risk_score\"] >= 1) | (df[\"mlp_flag\"] == 1),\n",
        "        \"MALICIOUS\",\n",
        "        \"BENIGN\"\n",
        "    )\n",
        "    return df\n",
        "\n",
        "class BinaryF1Score(keras.metrics.Metric):\n",
        "    def __init__(self, name='f1_score', threshold=0.5, **kwargs):\n",
        "        super().__init__(name=name, **kwargs)\n",
        "        self.threshold = threshold\n",
        "        self.precision = keras.metrics.Precision(thresholds=threshold)\n",
        "        self.recall = keras.metrics.Recall(thresholds=threshold)\n",
        "    def update_state(self, y_true, y_pred, sample_weight=None):\n",
        "        self.precision.update_state(y_true, y_pred, sample_weight)\n",
        "        self.recall.update_state(y_true, y_pred, sample_weight)\n",
        "    def result(self):\n",
        "        precision = self.precision.result()\n",
        "        recall = self.recall.result()\n",
        "        return 2 * ((precision * recall) / (precision + recall + tf.keras.backend.epsilon()))\n",
        "    def reset_state(self):\n",
        "        self.precision.reset_state()\n",
        "        self.recall.reset_state()\n",
        "    def get_config(self):\n",
        "        config = super().get_config()\n",
        "        config.update({'threshold': self.threshold})\n",
        "        return config\n",
        "\n",
        "app_model = tf.keras.models.load_model(\n",
        "    f\"{BASE_PATH}/app_mlp_model.keras\",\n",
        "    custom_objects={'BinaryF1Score': BinaryF1Score},\n",
        "    compile=False\n",
        ")\n",
        "\n",
        "app_model.compile(\n",
        "    optimizer=keras.optimizers.Adam(learning_rate=0.001),\n",
        "    loss='binary_crossentropy',\n",
        "    metrics=['accuracy']\n",
        ")\n",
        "print(\"✅ Model loaded successfully!\")"
      ],
